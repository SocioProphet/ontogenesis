@base <https://socioprophet.github.io/ontogenesis/> .
@prefix ex:    <https://socioprophet.github.io/ontogenesis/examples/corpus-event#> .
@prefix ces:   <https://socioprophet.github.io/ontogenesis/platform/corpus-event#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

ex:source-provenance-001 a ces:SourceProvenance ;
  rdfs:label "Confirmed bibliographic provenance" ;
  ces:sourceQuality "confirmed_bibliographic" ;
  ces:evidenceRef "SocioProphet/sociosphere#334:papers/index.jsonl" .

ex:evidence-bundle-001 a ces:CorpusEvidenceBundle ;
  rdfs:label "Watson/Cyc/CHRONOS corpus evidence bundle" ;
  ces:sourceQuality "confirmed_bibliographic" ;
  ces:evidenceRef "SocioProphet/sociosphere#334" .

ex:event-schema-chronos a ces:EventSchema ;
  rdfs:label "CHRONOS-style event schema" ;
  ces:evidenceRef "SocioProphet/sociosphere#334:evals/event-schema-instantiation.md" .

ex:event-instance-001 a ces:EventInstance ;
  rdfs:label "Synthetic CHRONOS-style event instance" ;
  ces:eventId "evt-synthetic-001" ;
  ces:eventType "corpus_reference_event" ;
  ces:claimStatus "candidate" ;
  ces:sourceQuality "confirmed_bibliographic" ;
  ces:usesEventSchema ex:event-schema-chronos ;
  ces:hasProvenance ex:source-provenance-001 .

ex:causal-candidate-001 a ces:CausalRelationCandidate ;
  rdfs:label "Synthetic WikiCausal-style causal candidate" ;
  ces:causeText "confirmed evidence source is attached" ;
  ces:effectText "implementation-grade action may be considered by a downstream policy gate" ;
  ces:confidence "0.72"^^xsd:decimal ;
  ces:claimStatus "candidate" ;
  ces:hasProvenance ex:source-provenance-001 .

ex:column-link-001 a ces:ColumnOntologyLink ;
  rdfs:label "Synthetic semantic table column link" ;
  ces:columnName "event_date" ;
  ces:ontologyTerm "schema:startDate" ;
  ces:confidence "0.90"^^xsd:decimal ;
  ces:claimStatus "candidate" .

ex:semantic-table-task-001 a ces:SemanticTableAnnotationTask ;
  rdfs:label "Synthetic semantic table annotation task" ;
  ces:hasColumnLink ex:column-link-001 ;
  ces:hasProvenance ex:source-provenance-001 .

ex:diagnostic-finding-001 a ces:DiagnosticFinding ;
  rdfs:label "Synthetic concept hierarchy diagnostic finding" ;
  ces:diagnosticCode "concept-hierarchy-inconsistency" ;
  ces:findingSeverity "low" ;
  ces:claimStatus "candidate" ;
  ces:hasEvidence ex:evidence-bundle-001 ;
  ces:hasProvenance ex:source-provenance-001 .
