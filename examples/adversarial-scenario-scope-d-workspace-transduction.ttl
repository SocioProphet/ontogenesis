@base <https://socioprophet.github.io/ontogenesis/> .
@prefix ex:    <https://socioprophet.github.io/ontogenesis/examples/adversarial-scenario#> .
@prefix scen:  <https://socioprophet.github.io/ontogenesis/domains/adversarial-scenario#> .
@prefix apt:   <https://socioprophet.github.io/ontogenesis/domains/agentic-purple-team#> .
@prefix mitre: <https://socioprophet.github.io/ontogenesis/alignments/mitre-attack#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

ex:workspace-transduction-001 a scen:AdversarialScenario ;
  scen:scenarioId "adversarial-scenario:workspace-transduction-001" ;
  scen:scenarioClass "workspace_transduction" ;
  scen:hasObjective ex:objective-001 ;
  scen:hasTargetTopology ex:target-topology-001 ;
  scen:usesChannelSubstrate ex:network-egress-channel , ex:dashboard-export-channel ;
  scen:crossesInterface ex:coverage-to-dashboard-crossing ;
  scen:hasHumanInterpretationRisk ex:operator-overtrust-risk ;
  scen:hasMachineInterpretationRisk ex:dashboard-policy-risk ;
  scen:usesTrustEdge ex:coverage-to-dashboard-trust-edge ;
  scen:hasCapabilityExposure ex:fail-closed-capability-exposure ;
  scen:hasEvidenceEnvelope ex:scout-header-evidence-envelope ;
  scen:hasRuntimeDecisionReceipt ex:allow-validate-runtime-receipt ;
  scen:mapsToTechniqueAnnotation mitre:ToolPoisoningEquivalent ;
  scen:hasMemoryEffect ex:learning-candidate-memory-effect ;
  scen:hasClaimPromotionState ex:triaged-claim-promotion-state ;
  scen:hasConsequenceModel ex:evidence-confusion-consequence ;
  scen:requiresAbstentionRule ex:no-technique-as-authority , ex:no-memory-writeback ;
  scen:hasCounterfactualBranch ex:dashboard-treated-as-authority ;
  scen:hasScenarioNonClaim ex:no-attack-execution , ex:no-engagement-authorization , ex:no-causal-attribution , ex:no-memory-writeback-claim ;
  scen:redactionState "redacted" ;
  scen:runtimeAuthority "false"^^xsd:boolean ;
  scen:procedureExecutionAuthority "false"^^xsd:boolean ;
  scen:engagementAuthorizationAuthority "false"^^xsd:boolean ;
  scen:activationAllowed "false"^^xsd:boolean ;
  rdfs:label "SCOPE-D workspace transduction adversarial scenario" .

ex:objective-001 a scen:ScenarioObjective ;
  rdfs:label "Validate that coverage cannot become authority" .

ex:target-topology-001 a scen:TargetTopology ;
  rdfs:label "Socioprophet lab target topology" .

ex:network-egress-channel a scen:ChannelSubstrate ;
  scen:channelType "network" ;
  rdfs:label "Lab browser network egress" .

ex:dashboard-export-channel a scen:ChannelSubstrate ;
  scen:channelType "dashboard" ;
  rdfs:label "Wargames dashboard export" .

ex:coverage-to-dashboard-crossing a scen:InterfaceCrossing ;
  rdfs:label "Coverage claim to dashboard export crossing" .

ex:operator-overtrust-risk a scen:HumanInterpretationRisk ;
  rdfs:label "Operator overtrust risk" .

ex:dashboard-policy-risk a scen:MachineInterpretationRisk ;
  rdfs:label "Dashboard policy interpretation risk" .

ex:coverage-to-dashboard-trust-edge a scen:TrustEdgeUse ;
  rdfs:label "Coverage to dashboard trust edge" .

ex:fail-closed-capability-exposure a scen:CapabilityExposure ;
  rdfs:label "Fail-closed capability exposure" .

ex:scout-header-evidence-envelope a apt:EvidenceEnvelope ;
  rdfs:label "Scout header evidence envelope" .

ex:allow-validate-runtime-receipt a apt:RunReceipt ;
  apt:receiptHash "1111111111111111111111111111111111111111111111111111111111111111" ;
  rdfs:label "Allow-validate runtime decision receipt" .

ex:learning-candidate-memory-effect a scen:MemoryEffect ;
  scen:writebackAllowed "false"^^xsd:boolean ;
  scen:proposalRequired "true"^^xsd:boolean ;
  scen:reviewState "pending_review" ;
  rdfs:label "Learning candidate memory effect" .

ex:triaged-claim-promotion-state a scen:ClaimPromotionState ;
  scen:promotionState "triaged" ;
  scen:findingAllowed "false"^^xsd:boolean ;
  scen:memoryUpdateAllowed "false"^^xsd:boolean ;
  rdfs:label "Triaged claim promotion state" .

ex:evidence-confusion-consequence a scen:ConsequenceModel ;
  scen:primaryConsequence "evidence_confusion" ;
  rdfs:label "Evidence confusion consequence model" .

ex:no-technique-as-authority a scen:AbstentionRule ;
  scen:requiredOutcome "do_not_promote" ;
  rdfs:label "Do not treat technique mapping as authority" .

ex:no-memory-writeback a scen:AbstentionRule ;
  scen:requiredOutcome "do_not_write_memory" ;
  rdfs:label "Do not write memory without proposal review" .

ex:dashboard-treated-as-authority a scen:CounterfactualBranch ;
  rdfs:label "Dashboard treated as authority counterfactual" .

ex:no-attack-execution a scen:ScenarioNonClaim ;
  rdfs:label "does not execute attack procedure" .

ex:no-engagement-authorization a scen:ScenarioNonClaim ;
  rdfs:label "does not authorize engagement" .

ex:no-causal-attribution a scen:ScenarioNonClaim ;
  rdfs:label "does not claim causal attribution" .

ex:no-memory-writeback-claim a scen:ScenarioNonClaim ;
  rdfs:label "does not promote memory writeback" .
