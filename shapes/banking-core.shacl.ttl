@base <https://socioprophet.github.io/ontogenesis/> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix banking: <https://socioprophet.github.io/ontogenesis/domains/banking#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<shapes/banking-core.shacl.ttl> a sh:NodeShape ;
  sh:targetClass banking:LegalEntity ;
  sh:message "Banking core SHACL bundle loaded." .

banking:LegalEntityShape a sh:NodeShape ;
  sh:targetClass banking:LegalEntity ;
  sh:property [
    sh:path banking:hasPortfolio ;
    sh:minCount 0 ;
  ] .

banking:FilingPackShape a sh:NodeShape ;
  sh:targetClass banking:FilingPack ;
  sh:property [
    sh:path banking:publicationStatus ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
  ] .
