@prefix hdt: <https://socioprophet.dev/ont/ontogenesis#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix biz: <https://socioprophet.github.io/ontogenesis/domains/business#> .
@prefix cs: <https://socioprophet.github.io/ontogenesis/domains/cybernetic-self#> .
@prefix party: <https://socioprophet.github.io/ontogenesis/domains/party#> .
@prefix legal: <https://socioprophet.github.io/ontogenesis/domains/legal#> .
@prefix ps: <https://socioprophet.github.io/ontogenesis/domains/product-service#> .

hdt:FHIRResourceShape a sh:NodeShape ;
  sh:targetClass hdt:FHIRResource ;
  sh:property [ sh:path hdt:hasOmegaState ;
                sh:in ( hdt:ABSENT hdt:SEEDED hdt:NORMALIZED hdt:LINKED hdt:TRUSTED hdt:ACTIONABLE hdt:DELIVERED ) ;
                sh:minCount 1 ] ;
  sh:property [ sh:path hdt:hasMembership ; sh:class hdt:MembershipVector ; sh:minCount 1 ] ;
  sh:property [ sh:path hdt:stepsToTruth ; sh:datatype xsd:integer ; sh:minInclusive 0 ] .

hdt:MembershipVectorShape a sh:NodeShape ;
  sh:targetClass hdt:MembershipVector ;
  sh:property [ sh:path hdt:mCBD ; sh:datatype xsd:decimal ; sh:minInclusive 0 ; sh:maxInclusive 1 ] ;
  sh:property [ sh:path hdt:mCGT ; sh:datatype xsd:decimal ; sh:minInclusive 0 ; sh:maxInclusive 1 ] ;
  sh:property [ sh:path hdt:mNHY ; sh:datatype xsd:decimal ; sh:minInclusive 0 ; sh:maxInclusive 1 ] .

cs:CyberneticSelfShape a sh:NodeShape ;
  sh:targetClass cs:CyberneticSelf ;
  sh:property [ sh:path cs:anchoredBy ; sh:minCount 1 ; sh:class cs:IdentityAnchor ] ;
  sh:property [ sh:path cs:hasObjectiveFunction ; sh:minCount 1 ; sh:class cs:ObjectiveFunction ] ;
  sh:property [ sh:path cs:hasEmbodiment ; sh:minCount 1 ; sh:class cs:FederatedEmbodiment ] ;
  sh:property [ sh:path cs:hasChamber ; sh:minCount 1 ; sh:class cs:Chamber ] ;
  sh:property [ sh:path cs:governedByCompact ; sh:minCount 1 ; sh:class cs:GovernanceCompact ] .

party:PartyShape a sh:NodeShape ;
  sh:targetClass party:Party ;
  sh:property [ sh:path party:hasIdentityRecord ; sh:minCount 1 ; sh:class party:IdentityRecord ] ;
  sh:property [ sh:path party:hasRoleAssignment ; sh:minCount 1 ; sh:class party:RoleAssignment ] .

party:RoleAssignmentShape a sh:NodeShape ;
  sh:targetClass party:RoleAssignment ;
  sh:property [ sh:path party:roleHeldBy ; sh:minCount 1 ; sh:class party:Party ] ;
  sh:property [ sh:path party:roleWithinSelf ; sh:minCount 1 ; sh:class cs:CyberneticSelf ] ;
  sh:property [ sh:path party:roleName ; sh:minCount 1 ; sh:datatype xsd:string ] .

legal:LegalEntityShape a sh:NodeShape ;
  sh:targetClass legal:LegalEntity ;
  sh:property [ sh:path legal:incorporatedIn ; sh:minCount 1 ; sh:class legal:Jurisdiction ] .

legal:OwnershipRelationShape a sh:NodeShape ;
  sh:targetClass legal:OwnershipRelation ;
  sh:property [ sh:path legal:ownedByEntity ; sh:minCount 1 ; sh:class legal:LegalEntity ] ;
  sh:property [ sh:path legal:ownsEntity ; sh:minCount 1 ; sh:class legal:LegalEntity ] .

legal:RepositoryAllocationShape a sh:NodeShape ;
  sh:targetClass legal:RepositoryAllocation ;
  sh:property [ sh:path legal:allocatesRepository ; sh:minCount 1 ; sh:class legal:RepositoryAsset ] ;
  sh:property [ sh:path legal:allocatedToEntity ; sh:minCount 1 ; sh:class legal:LegalEntity ] ;
  sh:property [ sh:path legal:allocationRuleText ; sh:minCount 1 ; sh:datatype xsd:string ] .

ps:ProductOfferingShape a sh:NodeShape ;
  sh:targetClass ps:ProductOffering ;
  sh:property [ sh:path ps:hasPlan ; sh:minCount 1 ; sh:class ps:Plan ] .

ps:ServiceOfferingShape a sh:NodeShape ;
  sh:targetClass ps:ServiceOffering ;
  sh:property [ sh:path ps:hasPlan ; sh:minCount 1 ; sh:class ps:Plan ] .

ps:PlanShape a sh:NodeShape ;
  sh:targetClass ps:Plan ;
  sh:property [ sh:path ps:planCode ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ps:soldAsSKU ; sh:minCount 1 ; sh:class ps:SKU ] ;
  sh:property [ sh:path ps:includesCapability ; sh:minCount 1 ; sh:class ps:Capability ] ;
  sh:property [ sh:path ps:grantsEntitlement ; sh:minCount 1 ; sh:class party:Entitlement ] ;
  sh:property [ sh:path ps:defaultSLA ; sh:minCount 1 ; sh:class ps:ServiceLevel ] ;
  sh:property [ sh:path ps:pricedInBook ; sh:minCount 1 ; sh:class ps:PriceBook ] .

ps:CapabilityShape a sh:NodeShape ;
  sh:targetClass ps:Capability ;
  sh:property [ sh:path ps:includesFeature ; sh:minCount 1 ; sh:class ps:Feature ] .

ps:ServiceInstanceShape a sh:NodeShape ;
  sh:targetClass ps:ServiceInstance ;
  sh:property [ sh:path ps:instantiatesPlan ; sh:minCount 1 ; sh:class ps:Plan ] ;
  sh:property [ sh:path ps:provisionedFor ; sh:minCount 1 ; sh:class party:Party ] ;
  sh:property [ sh:path ps:governedByProvider ; sh:minCount 1 ; sh:class legal:LegalEntity ] ;
  sh:property [ sh:path ps:billedUnderContract ; sh:minCount 1 ; sh:class biz:Contract ] .
