@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix scen:  <https://socioprophet.github.io/ontogenesis/domains/adversarial-scenario#> .
@prefix apt:   <https://socioprophet.github.io/ontogenesis/domains/agentic-purple-team#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

scen:AdversarialScenarioShape a sh:NodeShape ;
  sh:targetClass scen:AdversarialScenario ;
  sh:property [
    sh:path scen:scenarioId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:pattern "^adversarial-scenario:[a-z0-9][a-z0-9._:-]*$" ;
    sh:message "AdversarialScenario must have a stable adversarial-scenario:* ID." ;
  ] ;
  sh:property [
    sh:path scen:scenarioClass ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "AdversarialScenario must declare a scenario class." ;
  ] ;
  sh:property [
    sh:path scen:hasObjective ;
    sh:class scen:ScenarioObjective ;
    sh:minCount 1 ;
    sh:message "AdversarialScenario must reference a ScenarioObjective." ;
  ] ;
  sh:property [
    sh:path scen:usesChannelSubstrate ;
    sh:class scen:ChannelSubstrate ;
    sh:minCount 1 ;
    sh:message "AdversarialScenario must reference at least one ChannelSubstrate." ;
  ] ;
  sh:property [
    sh:path scen:hasEvidenceEnvelope ;
    sh:class apt:EvidenceEnvelope ;
    sh:minCount 1 ;
    sh:message "AdversarialScenario must reference at least one EvidenceEnvelope." ;
  ] ;
  sh:property [
    sh:path scen:hasRuntimeDecisionReceipt ;
    sh:class apt:RunReceipt ;
    sh:minCount 1 ;
    sh:message "AdversarialScenario must reference a runtime decision receipt before scenario export can be treated as governed." ;
  ] ;
  sh:property [
    sh:path scen:hasScenarioNonClaim ;
    sh:class scen:ScenarioNonClaim ;
    sh:minCount 3 ;
    sh:message "AdversarialScenario must carry explicit non-claims." ;
  ] ;
  sh:property [
    sh:path scen:runtimeAuthority ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "AdversarialScenario examples must not claim runtime authority." ;
  ] ;
  sh:property [
    sh:path scen:procedureExecutionAuthority ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "AdversarialScenario examples must not claim procedure execution authority." ;
  ] ;
  sh:property [
    sh:path scen:engagementAuthorizationAuthority ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "AdversarialScenario examples must not authorize engagement." ;
  ] ;
  sh:property [
    sh:path scen:activationAllowed ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "AdversarialScenario examples must not activate downstream delivery." ;
  ] .

scen:TechniqueAnnotationBoundaryShape a sh:NodeShape ;
  sh:targetClass scen:AdversarialScenario ;
  sh:property [
    sh:path scen:mapsToTechniqueAnnotation ;
    sh:class apt:Technique ;
    sh:message "Technique mappings are annotations only; authority/evidence/promotion must be represented separately." ;
  ] ;
  sh:property [
    sh:path scen:requiresAbstentionRule ;
    sh:class scen:AbstentionRule ;
    sh:minCount 1 ;
    sh:message "Technique-annotated scenarios require at least one abstention rule." ;
  ] .

scen:MemoryEffectShape a sh:NodeShape ;
  sh:targetClass scen:MemoryEffect ;
  sh:property [
    sh:path scen:writebackAllowed ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "MemoryEffect must not authorize durable writeback." ;
  ] ;
  sh:property [
    sh:path scen:proposalRequired ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue true ;
    sh:message "MemoryEffect must require proposal routing." ;
  ] ;
  sh:property [
    sh:path scen:reviewState ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:in ( "pending_review" "blocked" ) ;
    sh:message "MemoryEffect review state must remain pending_review or blocked." ;
  ] .

scen:ClaimPromotionStateShape a sh:NodeShape ;
  sh:targetClass scen:ClaimPromotionState ;
  sh:property [
    sh:path scen:promotionState ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:in ( "raw" "hypothesis" "triaged" "blocked" ) ;
    sh:message "ClaimPromotionState examples must remain raw, hypothesis, triaged, or blocked." ;
  ] ;
  sh:property [
    sh:path scen:findingAllowed ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "ClaimPromotionState must not allow finding promotion in examples." ;
  ] ;
  sh:property [
    sh:path scen:memoryUpdateAllowed ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:hasValue false ;
    sh:message "ClaimPromotionState must not allow memory update in examples." ;
  ] .
