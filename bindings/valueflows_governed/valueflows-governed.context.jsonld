{
  "@version": 1.1,
  "@vocab": "https://socioprophet.dev/ont/valueflows-governed#",
  "vfg": "https://socioprophet.dev/ont/valueflows-governed#",
  "xsd": "http://www.w3.org/2001/XMLSchema#",
  "ProcessRun": "vfg:ProcessRun",
  "Task": "vfg:Task",
  "Delegation": "vfg:Delegation",
  "CapabilityGrant": "vfg:CapabilityGrant",
  "Commitment": "vfg:Commitment",
  "CairnCheckpoint": "vfg:CairnCheckpoint",
  "groupId": {"@id": "vfg:groupId", "@type": "@id"},
  "createdBy": {"@id": "vfg:createdBy", "@type": "@id"},
  "grantorActorId": {"@id": "vfg:grantorActorId", "@type": "@id"},
  "granteeActorId": {"@id": "vfg:granteeActorId", "@type": "@id"},
  "processRunId": {"@id": "vfg:processRunId", "@type": "@id"},
  "taskId": {"@id": "vfg:taskId", "@type": "@id"},
  "delegationId": {"@id": "vfg:delegationId", "@type": "@id"},
  "offeredBy": {"@id": "vfg:offeredBy", "@type": "@id"},
  "acceptedBy": {"@id": "vfg:acceptedBy", "@type": "@id"},
  "debtorActorId": {"@id": "vfg:debtorActorId", "@type": "@id"},
  "outcomeRef": {"@id": "vfg:outcomeRef", "@type": "@id"},
  "status": "vfg:status",
  "title": "vfg:title",
  "processKind": "vfg:processKind",
  "delegationKind": "vfg:delegationKind",
  "capabilityScope": "vfg:capabilityScope",
  "capability": "vfg:capability",
  "stateProjectionName": "vfg:stateProjectionName",
  "materializedStateHash": "vfg:materializedStateHash",
  "validFrom": {"@id": "vfg:validFrom", "@type": "xsd:dateTime"},
  "validUntil": {"@id": "vfg:validUntil", "@type": "xsd:dateTime"},
  "startedAt": {"@id": "vfg:startedAt", "@type": "xsd:dateTime"},
  "plannedEndAt": {"@id": "vfg:plannedEndAt", "@type": "xsd:dateTime"},
  "dueAt": {"@id": "vfg:dueAt", "@type": "xsd:dateTime"},
  "completedAt": {"@id": "vfg:completedAt", "@type": "xsd:dateTime"},
  "progressPercent": {"@id": "vfg:progressPercent", "@type": "xsd:integer"}
}
