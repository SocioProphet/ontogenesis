    },
    "alignsSubject": {
      "@id": "kcc:alignsSubject",
      "@type": "@id"
    },
    "inKnowledgeContext": {
      "@id": "kcc:inKnowledgeContext",
      "@type": "@id"
    },
    "schemaLabel": "kc:schemaLabel",
    "contextLabel": "kc:contextLabel"
  }
}
