    "SourceAnchor": "systema:SourceAnchor",
    "ConceptDefinition": "systema:ConceptDefinition",
    "ConceptUseBoundary": "systema:ConceptUseBoundary",
    "ImplementationSurface": "systema:ImplementationSurface",
    "EvidenceRequirement": "systema:EvidenceRequirement",
    "ConceptRevision": "systema:ConceptRevision",
    "conceptId": "systema:conceptId",
    "sourceAnchor": {
      "@id": "systema:sourceAnchor",
      "@type": "@id"
    },
    "sourceRef": "systema:sourceRef",
    "sourceKind": "systema:sourceKind",
    "extractionConfidence": "systema:extractionConfidence",
    "reviewState": "systema:reviewState",
    "quoteBoundary": "systema:quoteBoundary",
    "uncertaintyNote": "systema:uncertaintyNote",
    "definition": {
      "@id": "systema:definition",
      "@type": "@id"
    },
    "definitionText": "systema:definitionText",
    "operationalDefinition": "systema:operationalDefinition",
    "claimLevel": "systema:claimLevel",
    "allowedUse": "systema:allowedUse",
    "forbiddenUse": "systema:forbiddenUse",
    "implementationSurface": {
      "@id": "systema:implementationSurface",
      "@type": "@id"
    },
    "ownerRepo": "systema:ownerRepo",
    "surfacePath": "systema:surfacePath",
    "evidenceRequirement": {
      "@id": "systema:evidenceRequirement",
      "@type": "@id"
    },
    "evidenceRequirementText": "systema:evidenceRequirementText",
    "promotionState": "systema:promotionState",
    "revision": {
      "@id": "systema:revision",
      "@type": "@id"
    },
    "revisionNote": "systema:revisionNote",
