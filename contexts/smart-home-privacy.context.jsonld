{
  "@context": {
    "@version": 1.1,
    "shp": "https://socioprophet.github.io/ontogenesis/domains/smart-home-privacy#",
    "upper": "https://socioprophet.github.io/ontogenesis/upper#",
    "id": "@id",
    "type": "@type",
    "label": "http://www.w3.org/2000/01/rdf-schema#label",
    "vendor": {"@id": "shp:hasVendor", "@type": "@id"},
    "deviceType": {"@id": "shp:hasDeviceType", "@type": "@id"},
    "capability": {"@id": "shp:hasCapability", "@type": "@id", "@container": "@set"},
    "dataAttribute": {"@id": "shp:emitsDataAttribute", "@type": "@id", "@container": "@set"},
    "physicalContext": {"@id": "shp:locatedInContext", "@type": "@id"},
    "policyCoversDevice": {"@id": "shp:policyCoversDevice", "@type": "@id", "@container": "@set"},
    "assertsClaim": {"@id": "shp:assertsClaim", "@type": "@id", "@container": "@set"},
    "claimDataAttribute": {"@id": "shp:claimDataAttribute", "@type": "@id", "@container": "@set"},
    "claimDeviceType": {"@id": "shp:claimDeviceType", "@type": "@id", "@container": "@set"},
    "evidenceForClaim": {"@id": "shp:evidenceForClaim", "@type": "@id"},
    "findingSubject": {"@id": "shp:findingSubject", "@type": "@id"},
    "findingType": {"@id": "shp:findingType", "@type": "@id"},
    "hasRiskInference": {"@id": "shp:hasRiskInference", "@type": "@id", "@container": "@set"},
    "gaiaContext": {"@id": "shp:gaiaContext", "@type": "@id"},
    "hdtImpact": {"@id": "shp:hdtImpact", "@type": "@id"},
    "requiresConsentBoundary": {"@id": "shp:requiresConsentBoundary", "@type": "@id"},
    "purposeText": "shp:purposeText",
    "destinationText": "shp:destinationText",
    "jurisdictionText": "shp:jurisdictionText",
    "policyHash": "shp:policyHash",
    "crawlPath": "shp:crawlPath",
    "observedAt": {"@id": "shp:observedAt", "@type": "http://www.w3.org/2001/XMLSchema#dateTime"},
    "confidenceScore": {"@id": "shp:confidenceScore", "@type": "http://www.w3.org/2001/XMLSchema#decimal"},
    "sensitivityTier": "shp:sensitivityTier"
  }
}
