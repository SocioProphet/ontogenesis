{
  "@context": {
    "@version": 1.1,
    "view": "https://socioprophet.github.io/ontogenesis/platform/view#",
    "upper": "https://socioprophet.github.io/ontogenesis/upper#",
    "plat": "https://socioprophet.github.io/ontogenesis/platform#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "label": "rdfs:label",
    "ViewContract": "view:ViewContract",
    "ViewSignature": "view:ViewSignature",
    "PrincipalAuthority": "view:PrincipalAuthority",
    "AgentAuthority": "view:AgentAuthority",
    "PolicyAuthority": "view:PolicyAuthority",
    "WorkspaceAuthority": "view:WorkspaceAuthority",
    "RuntimeEvidenceAuthority": "view:RuntimeEvidenceAuthority",
    "TraversalEvidenceAuthority": "view:TraversalEvidenceAuthority",
    "DisclosureMode": "view:DisclosureMode",
    "RevocationEpoch": "view:RevocationEpoch",
    "TypedAbsence": "view:TypedAbsence",
    "hasViewSignature": { "@id": "view:hasViewSignature", "@type": "@id" },
    "hasPrincipalAuthority": { "@id": "view:hasPrincipalAuthority", "@type": "@id" },
    "hasAgentAuthority": { "@id": "view:hasAgentAuthority", "@type": "@id" },
    "hasPolicyAuthority": { "@id": "view:hasPolicyAuthority", "@type": "@id" },
    "hasWorkspaceAuthority": { "@id": "view:hasWorkspaceAuthority", "@type": "@id" },
    "hasDisclosureMode": { "@id": "view:hasDisclosureMode", "@type": "@id" },
    "hasRevocationEpoch": { "@id": "view:hasRevocationEpoch", "@type": "@id" },
    "hasRuntimeEvidenceAuthority": { "@id": "view:hasRuntimeEvidenceAuthority", "@type": "@id" },
    "hasTraversalEvidenceAuthority": { "@id": "view:hasTraversalEvidenceAuthority", "@type": "@id" },
    "authorityRef": "view:authorityRef",
    "contractHash": "view:contractHash",
    "viewSignatureHash": "view:viewSignatureHash",
    "revocationEpochValue": { "@id": "view:revocationEpochValue", "@type": "xsd:integer" },
    "absenceReason": "view:absenceReason"
  }
}
