@base <https://socioprophet.github.io/ontogenesis/> .
@prefix ngov:  <https://socioprophet.github.io/ontogenesis/middle/named-graph-governance#> .
@prefix kgl:   <https://socioprophet.github.io/ontogenesis/middle/kg-lifecycle#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .

<Middle/named-graph-governance.ttl> a owl:Ontology ;
  dct:title "Middle — Named Graph Governance" ;
  dct:description "Cross-domain vocabulary for named graph context, source isolation, provenance, trust, access class, lifecycle phase, versioning, and retention." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Middle/kg-lifecycle.ttl> .

ngov:NamedGraph a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Named graph" .
ngov:SourceGraph a owl:Class ; rdfs:subClassOf ngov:NamedGraph ; rdfs:label "Source graph" .
ngov:CuratedGraph a owl:Class ; rdfs:subClassOf ngov:NamedGraph ; rdfs:label "Curated graph" .
ngov:InferenceGraph a owl:Class ; rdfs:subClassOf ngov:NamedGraph ; rdfs:label "Inference graph" .
ngov:RestrictedGraph a owl:Class ; rdfs:subClassOf ngov:NamedGraph ; rdfs:label "Restricted graph" .
ngov:GraphAccessPolicy a owl:Class ; rdfs:subClassOf upper:Policy ; rdfs:label "Graph access policy" .
ngov:GraphTrustProfile a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Graph trust profile" .

ngov:hasAccessPolicy a owl:ObjectProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range ngov:GraphAccessPolicy ; rdfs:label "has access policy" .
ngov:hasTrustProfile a owl:ObjectProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range ngov:GraphTrustProfile ; rdfs:label "has trust profile" .
ngov:graphLifecyclePhase a owl:ObjectProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range kgl:LifecyclePhase ; rdfs:label "graph lifecycle phase" .
ngov:generatedByPipeline a owl:ObjectProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range kgl:Pipeline ; rdfs:label "generated by pipeline" .
ngov:graphOwner a owl:ObjectProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range prov:Agent ; rdfs:label "graph owner" .

ngov:graphURI a owl:DatatypeProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range xsd:anyURI ; rdfs:label "graph URI" .
ngov:sourceSystem a owl:DatatypeProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range xsd:string ; rdfs:label "source system" .
ngov:trustLevel a owl:DatatypeProperty ; rdfs:domain ngov:GraphTrustProfile ; rdfs:range xsd:string ; rdfs:label "trust level" .
ngov:accessClass a owl:DatatypeProperty ; rdfs:domain ngov:GraphAccessPolicy ; rdfs:range xsd:string ; rdfs:label "access class" .
ngov:effectiveDate a owl:DatatypeProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range xsd:date ; rdfs:label "effective date" .
ngov:bindingEpoch a owl:DatatypeProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range xsd:string ; rdfs:label "binding epoch" .
ngov:retentionPolicy a owl:DatatypeProperty ; rdfs:domain ngov:GraphAccessPolicy ; rdfs:range xsd:string ; rdfs:label "retention policy" .
ngov:perspectiveLabel a owl:DatatypeProperty ; rdfs:domain ngov:NamedGraph ; rdfs:range xsd:string ; rdfs:label "perspective label" .
