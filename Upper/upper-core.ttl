@base <https://socioprophet.github.io/ontogenesis/> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

<Upper/upper-core.ttl> a owl:Ontology ;
  dct:title "Ontogenesis Upper Core" ;
  dct:description "Foundational primitives for the Ontogenesis ontology stack." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <http://www.w3.org/ns/prov-o> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> ;
  owl:imports <http://purl.org/dc/terms/> .

### Core categories
upper:Entity a owl:Class ; rdfs:label "Entity" .
upper:Process a owl:Class ; rdfs:label "Process" .
upper:Agent a owl:Class ; rdfs:subClassOf upper:Entity ; rdfs:label "Agent" .
upper:System a owl:Class ; rdfs:subClassOf upper:Entity ; rdfs:label "System" .
upper:InformationArtifact a owl:Class ; rdfs:subClassOf upper:Entity ; rdfs:label "Information Artifact" .
upper:Policy a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Policy" .
upper:Evidence a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Evidence" .
upper:Assertion a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Assertion" .

### Governance / audit primitives
upper:Ledger a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Ledger" .
upper:LedgerEntry a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Ledger Entry" .
upper:Signature a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Signature" .
upper:Signer a owl:Class ; rdfs:subClassOf upper:Agent ; rdfs:label "Signer" .

### Useful relations
upper:hasPart a owl:ObjectProperty ; rdfs:domain upper:Entity ; rdfs:range upper:Entity ; rdfs:label "has part" .
upper:dependsOn a owl:ObjectProperty ; rdfs:domain upper:Entity ; rdfs:range upper:Entity ; rdfs:label "depends on" .
upper:describes a owl:ObjectProperty ; rdfs:domain upper:InformationArtifact ; rdfs:range upper:Entity ; rdfs:label "describes" .

upper:hasIdentifier a owl:DatatypeProperty ; rdfs:domain upper:Entity ; rdfs:range xsd:string ; rdfs:label "has identifier" .
upper:hasVersion a owl:DatatypeProperty ; rdfs:domain upper:Entity ; rdfs:range xsd:string ; rdfs:label "has version" .
upper:status a owl:DatatypeProperty ; rdfs:domain upper:Entity ; rdfs:range xsd:string ; rdfs:label "status" .

### Provenance alignment helpers
upper:wasGeneratedBy a owl:ObjectProperty ;
  rdfs:subPropertyOf prov:wasGeneratedBy ;
  rdfs:domain upper:InformationArtifact ;
  rdfs:range prov:Activity ;
  rdfs:label "was generated by" .

upper:wasAttributedTo a owl:ObjectProperty ;
  rdfs:subPropertyOf prov:wasAttributedTo ;
  rdfs:domain upper:InformationArtifact ;
  rdfs:range prov:Agent ;
  rdfs:label "was attributed to" .

