{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/prophet-artifact.schema.json",
  "title": "Prophet Computational Artifact",
  "description": "Governed executable knowledge artifact contract for Prophet Platform, Ontogenesis, Sociosphere, Sherlock, Lattice Forge, and SourceOS workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "socioprophet.org/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "ProphetArtifact"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "ownerRepo"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
        },
        "ownerRepo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "maintainers": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "slashTopics": {
          "type": "array",
          "items": { "type": "string", "pattern": "^/[a-z0-9][a-z0-9/_-]*$" },
          "uniqueItems": true
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactKind", "actions", "runtime", "provenance", "policy", "evidence", "metrics"],
      "properties": {
        "artifactKind": {
          "type": "string",
          "enum": ["workflow", "dataset", "model", "benchmark", "notebook", "runtime", "paper", "agent-skill", "scoreboard"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ioObject" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ioObject" }
        },
        "runtime": { "$ref": "#/$defs/runtime" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "policy": { "$ref": "#/$defs/policy" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "registrations": { "$ref": "#/$defs/registrations" }
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "verb"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "verb": {
          "type": "string",
          "enum": ["detect", "fetch", "prepare", "build", "run", "validate", "benchmark", "tune", "publish", "attest"]
        },
        "adapter": { "type": "string" },
        "command": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "requiresNetwork": { "type": "boolean", "default": false },
        "privileged": { "type": "boolean", "default": false }
      }
    },
    "ioObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string", "enum": ["file", "directory", "uri", "dataset", "model", "table", "tile", "api", "receipt", "log", "sbom", "signature", "metric"] },
        "path": { "type": "string" },
        "uri": { "type": "string" },
        "schema": { "type": "string" },
        "contentType": { "type": "string" },
        "checksum": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["substrate"],
      "properties": {
        "substrate": { "type": "string", "enum": ["local", "container", "lattice-forge", "sourceos", "kubernetes", "notebook", "beam", "ray"] },
        "profile": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "hardware": { "type": "array", "items": { "type": "string" } },
        "environment": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceUri", "license", "attribution"],
      "properties": {
        "sourceUri": { "type": "string" },
        "license": { "type": "string" },
        "attribution": { "type": "string" },
        "receipts": { "type": "array", "items": { "type": "string" } },
        "freshness": { "type": "string" },
        "lineage": { "type": "array", "items": { "type": "string" } }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["safetyClass", "promotionGate"],
      "properties": {
        "safetyClass": { "type": "string", "enum": ["advisory", "bounded", "privileged", "prohibited"] },
        "promotionGate": { "type": "string" },
        "networkPosture": { "type": "string", "enum": ["offline", "allowlisted", "unrestricted"] },
        "requiresHumanReview": { "type": "boolean" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logs", "checksums"],
      "properties": {
        "logs": { "type": "array", "items": { "type": "string" } },
        "checksums": { "type": "array", "items": { "type": "string" } },
        "sboms": { "type": "array", "items": { "type": "string" } },
        "signatures": { "type": "array", "items": { "type": "string" } },
        "lineage": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit"],
      "properties": {
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "threshold": { "type": ["number", "string"] },
        "direction": { "type": "string", "enum": ["minimize", "maximize", "informational"] },
        "publishToScoreboard": { "type": "boolean", "default": false }
      }
    },
    "registrations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sociosphere": { "type": "boolean" },
        "sherlock": { "type": "boolean" },
        "holmes": { "type": "boolean" },
        "deliveryExcellence": { "type": "boolean" }
      }
    }
  }
}
