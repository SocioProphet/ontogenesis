@base <https://socioprophet.github.io/ontogenesis/> .
@prefix ex:    <https://socioprophet.github.io/ontogenesis/examples/corpus-event#> .
@prefix ces:   <https://socioprophet.github.io/ontogenesis/platform/corpus-event#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

ex:event-schema-chronos-invalid a ces:EventSchema ;
  rdfs:label "CHRONOS-style event schema" ;
  ces:evidenceRef "SocioProphet/sociosphere#334:evals/event-schema-instantiation.md" .

ex:event-instance-missing-provenance a ces:EventInstance ;
  rdfs:label "Invalid event instance missing provenance" ;
  ces:eventId "evt-invalid-001" ;
  ces:eventType "corpus_reference_event" ;
  ces:claimStatus "candidate" ;
  ces:sourceQuality "confirmed_bibliographic" ;
  ces:usesEventSchema ex:event-schema-chronos-invalid .
