@base <https://socioprophet.github.io/ontogenesis/> .
@prefix align: <https://socioprophet.github.io/ontogenesis/alignments#> .
@prefix smap:  <https://socioprophet.github.io/ontogenesis/middle/semantic-mapping#> .
@prefix cyber: <https://socioprophet.github.io/ontogenesis/domains/cyber#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix case-investigation: <https://ontology.caseontology.org/case/investigation/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Alignments/uco-case.ttl> a owl:Ontology ;
  dct:title "Alignment — UCO / CASE" ;
  dct:description "Governed alignment scaffold from Ontogenesis cyber/evidence concepts to UCO and CASE cyber-investigation semantics." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Domains/cyber.ttl>, <Middle/semantic-mapping.ttl> .

align:ucoExternalOntology a smap:ExternalOntology ;
  smap:standardName "Unified Cyber Ontology" ;
  smap:standardVersion "external" ;
  smap:standardUrl "https://unifiedcyberontology.org/" ;
  rdfs:label "UCO" .

align:caseExternalOntology a smap:ExternalOntology ;
  smap:standardName "Cyber-investigation Analysis Standard Expression" ;
  smap:standardVersion "external" ;
  smap:standardUrl "https://caseontology.org/" ;
  rdfs:label "CASE" .

align:SecurityEventToUcoAction a smap:MappingAssertion ;
  smap:mapsFrom cyber:SecurityEvent ;
  smap:mapsTo uco-core:Action ;
  smap:usesMappingPredicate smap:SkosCloseMatch ;
  smap:targetOntology align:ucoExternalOntology ;
  smap:confidence 0.72 ;
  smap:status "draft" ;
  smap:rationale "Security event can often be interpreted as an observed or reported cyber action, but exact modeling varies by source." .

align:FindingToCaseTrace a smap:MappingAssertion ;
  smap:mapsFrom cyber:Finding ;
  smap:mapsTo case-investigation:Trace ;
  smap:usesMappingPredicate smap:SkosCloseMatch ;
  smap:targetOntology align:caseExternalOntology ;
  smap:confidence 0.68 ;
  smap:status "draft" ;
  smap:rationale "Security findings may become investigative traces when admitted into an investigation context." .

align:EvidenceToCaseInvestigativeAction a smap:MappingAssertion ;
  smap:mapsFrom upper:Evidence ;
  smap:mapsTo case-investigation:InvestigativeAction ;
  smap:usesMappingPredicate smap:SkosBroadMatch ;
  smap:targetOntology align:caseExternalOntology ;
  smap:confidence 0.55 ;
  smap:status "draft" ;
  smap:rationale "Evidence is not itself an action; this mapping flags the evidence/action boundary for later CASE-specific modeling." .
