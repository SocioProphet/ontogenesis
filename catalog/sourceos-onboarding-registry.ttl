@base <https://socioprophet.github.io/ontogenesis/> .
@prefix og: <https://socioprophet.github.io/ontogenesis/og#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<catalog/sourceos-onboarding-registry.ttl> a owl:Ontology ;
  dct:title "SourceOS Onboarding Registry Supplement" ;
  dct:description "Supplemental registry entries for the SourceOS/SociOS onboarding semantic tranche." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <catalog/registry.ttl> .

og:SourceOSOnboarding a og:Module ;
  og:layer "Platform" ;
  og:path "Platform/sourceos/onboarding.ttl" ;
  og:baseIRI "https://schemas.srcos.ai/v2/" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "SourceOS onboarding control plane" .

og:SourceOSOnboardingShapes a og:Module ;
  og:layer "Shapes" ;
  og:path "shapes/sourceos/onboarding.shacl.ttl" ;
  og:baseIRI "https://schemas.srcos.ai/v2/" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "SourceOS onboarding SHACL gates" .

og:SourceOSOnboardingExample a og:Module ;
  og:layer "Examples" ;
  og:path "examples/sourceos/onboarding-receipt-example.jsonld" ;
  og:baseIRI "https://schemas.srcos.ai/v2/" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "SourceOS onboarding receipt example" .

og:SourceOSOnboardingSpec a og:Module ;
  og:layer "Specifications" ;
  og:path "docs/specs/sourceos-onboarding-semantics.md" ;
  og:baseIRI "https://schemas.srcos.ai/v2/" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "SourceOS onboarding semantics specification" .
