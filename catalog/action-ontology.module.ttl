@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

# Temporary registry supplement for the Action Ontology module.
# Intended to be folded into catalog/registry.ttl.

og:MiddleActionOntology a og:Module ;
  og:layer "Middle" ;
  og:path "Middle/action-ontology.ttl" ;
  og:baseIRI "https://socioprophet.github.io/ontogenesis/middle/action#" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "Action ontology" .
