@base <https://socioprophet.github.io/ontogenesis/> .
@prefix og: <https://socioprophet.github.io/ontogenesis/og#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<catalog/registry.ttl> a owl:Ontology ;
  dct:title "Ontogenesis Module Registry" ;
  dct:description "Machine-readable index of Ontogenesis modules, SemVer, layer, and import relations." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl> .

og:Module a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Module" .
og:layer a owl:DatatypeProperty ; rdfs:domain og:Module ; rdfs:range xsd:string ; rdfs:label "layer" .
og:path a owl:DatatypeProperty ; rdfs:domain og:Module ; rdfs:range xsd:string ; rdfs:label "path" .
og:baseIRI a owl:DatatypeProperty ; rdfs:domain og:Module ; rdfs:range xsd:string ; rdfs:label "base IRI" .
og:semver a owl:DatatypeProperty ; rdfs:domain og:Module ; rdfs:range xsd:string ; rdfs:label "semver" .
og:status a owl:DatatypeProperty ; rdfs:domain og:Module ; rdfs:range xsd:string ; rdfs:label "status" .

og:UpperCore a og:Module ; og:layer "Upper" ; og:path "Upper/upper-core.ttl" ; og:baseIRI "https://socioprophet.github.io/ontogenesis/upper#" ; og:semver "0.1.0" ; og:status "draft" ; rdfs:label "Upper core" .
og:UpperAlignments a og:Module ; og:layer "Upper" ; og:path "Upper/upper-alignments.ttl" ; og:baseIRI "https://socioprophet.github.io/ontogenesis/upper#" ; og:semver "0.1.0" ; og:status "draft" ; rdfs:label "Upper alignments" .

og:MiddleSystem a og:Module ; og:layer "Middle" ; og:path "Middle/system-architecture.ttl" ; og:baseIRI "https://socioprophet.github.io/ontogenesis/middle#" ; og:semver "0.1.0" ; og:status "draft" ; rdfs:label "System architecture" .
og:MiddleRegistries a og:Module ; og:layer "Middle" ; og:path "Middle/registries.ttl" ; og:baseIRI "https://socioprophet.github.io/ontogenesis/middle#" ; og:semver "0.1.0" ; og:status "draft" ; rdfs:label "Registries" .
