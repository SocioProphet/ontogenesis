@base <https://socioprophet.github.io/ontogenesis/> .
@prefix og: <https://socioprophet.github.io/ontogenesis/og#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<catalog/smart_home_privacy_registry.ttl> a owl:Ontology ;
  dct:title "Smart Home Privacy Registry Supplement" ;
  dct:description "Registry supplement for the smart-home privacy domain pack. This supplement avoids competing with the root registry while keeping the tranche discoverable for downstream compilers." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <catalog/registry.ttl> .

og:DomainSmartHomePrivacy a og:Module ;
  og:layer "Domains" ;
  og:path "Domains/smart-home-privacy.ttl" ;
  og:baseIRI "https://socioprophet.github.io/ontogenesis/domains/smart-home-privacy#" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "Smart home privacy domain" .

og:SmartHomePrivacyShapes a og:Module ;
  og:layer "Shapes" ;
  og:path "shapes/smart-home-privacy.shacl.ttl" ;
  og:baseIRI "https://socioprophet.github.io/ontogenesis/domains/smart-home-privacy#" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "Smart home privacy SHACL gates" .

og:SmartHomePrivacyBridgeSpec a og:Module ;
  og:layer "Specifications" ;
  og:path "docs/specs/smart_home_privacy_gaia_hdt_bridge.md" ;
  og:baseIRI "https://socioprophet.github.io/ontogenesis/domains/smart-home-privacy#" ;
  og:semver "0.1.0" ;
  og:status "draft" ;
  rdfs:label "Smart home privacy GAIA/HDT bridge specification" .
