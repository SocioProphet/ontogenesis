@base <https://socioprophet.github.io/ontogenesis/> .
@prefix scen: <https://socioprophet.github.io/ontogenesis/domains/adversarial-scenario#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

<Domains/adversarial-scenario.ttl> a owl:Ontology ;
  dct:title "Domain - Adversarial Scenario" ;
  dct:description "Scenario-level vocabulary for governed SCOPE-D adversarial scenarios. This tranche defines the standalone vocabulary only; SHACL gates, examples, registry projection, and cross-module subclassing are deferred to follow-up validator tranches." ;
  owl:versionInfo "0.1.0" .

scen:AdversarialScenario a owl:Class ;
  rdfs:label "Adversarial scenario" ;
  rdfs:comment "A governed composition artifact binding objective, topology, channels, interface crossings, authority, safety, evidence, technique annotations, runtime receipts, memory effects, claim-promotion state, consequence, abstention rules, and non-claims." .

scen:ScenarioObjective a owl:Class ; rdfs:label "Scenario objective" .
scen:TargetTopology a owl:Class ; rdfs:label "Target topology" .
scen:ChannelSubstrate a owl:Class ; rdfs:label "Channel substrate" .
scen:InterfaceCrossing a owl:Class ; rdfs:label "Interface crossing" .
scen:HumanInterpretationRisk a owl:Class ; rdfs:label "Human interpretation risk" .
scen:MachineInterpretationRisk a owl:Class ; rdfs:label "Machine interpretation risk" .
scen:TrustEdgeUse a owl:Class ; rdfs:label "Trust edge use" .
scen:MemoryEffect a owl:Class ; rdfs:label "Memory effect" .
scen:ClaimPromotionState a owl:Class ; rdfs:label "Claim promotion state" .
scen:ConsequenceModel a owl:Class ; rdfs:label "Consequence model" .
scen:AbstentionRule a owl:Class ; rdfs:label "Abstention rule" .
scen:CounterfactualBranch a owl:Class ; rdfs:label "Counterfactual branch" .
scen:CapabilityExposure a owl:Class ; rdfs:label "Capability exposure" .
scen:ScenarioNonClaim a owl:Class ; rdfs:label "Scenario non-claim" .

scen:scenarioId a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:string ; rdfs:label "scenario ID" .
scen:scenarioClass a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:string ; rdfs:label "scenario class" .
scen:safetyMode a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:label "safety mode" .
scen:redactionState a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:label "redaction state" .
scen:runtimeAuthority a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:boolean ; rdfs:label "runtime authority" .
scen:procedureExecutionAuthority a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:boolean ; rdfs:label "procedure execution authority" .
scen:engagementAuthorizationAuthority a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:boolean ; rdfs:label "engagement authorization authority" .
scen:activationAllowed a owl:DatatypeProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range xsd:boolean ; rdfs:label "activation allowed" .
scen:writebackAllowed a owl:DatatypeProperty ; rdfs:domain scen:MemoryEffect ; rdfs:range xsd:boolean ; rdfs:label "writeback allowed" .
scen:proposalRequired a owl:DatatypeProperty ; rdfs:domain scen:MemoryEffect ; rdfs:range xsd:boolean ; rdfs:label "proposal required" .
scen:reviewState a owl:DatatypeProperty ; rdfs:domain scen:MemoryEffect ; rdfs:range xsd:string ; rdfs:label "review state" .
scen:promotionState a owl:DatatypeProperty ; rdfs:domain scen:ClaimPromotionState ; rdfs:range xsd:string ; rdfs:label "promotion state" .
scen:findingAllowed a owl:DatatypeProperty ; rdfs:domain scen:ClaimPromotionState ; rdfs:range xsd:boolean ; rdfs:label "finding allowed" .
scen:memoryUpdateAllowed a owl:DatatypeProperty ; rdfs:domain scen:ClaimPromotionState ; rdfs:range xsd:boolean ; rdfs:label "memory update allowed" .
scen:primaryConsequence a owl:DatatypeProperty ; rdfs:domain scen:ConsequenceModel ; rdfs:range xsd:string ; rdfs:label "primary consequence" .
scen:channelType a owl:DatatypeProperty ; rdfs:domain scen:ChannelSubstrate ; rdfs:range xsd:string ; rdfs:label "channel type" .
scen:requiredOutcome a owl:DatatypeProperty ; rdfs:domain scen:AbstentionRule ; rdfs:range xsd:string ; rdfs:label "required outcome" .

scen:hasObjective a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:ScenarioObjective ; rdfs:label "has objective" .
scen:hasTargetTopology a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:TargetTopology ; rdfs:label "has target topology" .
scen:usesChannelSubstrate a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:ChannelSubstrate ; rdfs:label "uses channel substrate" .
scen:crossesInterface a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:InterfaceCrossing ; rdfs:label "crosses interface" .
scen:hasHumanInterpretationRisk a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:HumanInterpretationRisk ; rdfs:label "has human interpretation risk" .
scen:hasMachineInterpretationRisk a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:MachineInterpretationRisk ; rdfs:label "has machine interpretation risk" .
scen:usesTrustEdge a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:TrustEdgeUse ; rdfs:label "uses trust edge" .
scen:hasCapabilityExposure a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:CapabilityExposure ; rdfs:label "has capability exposure" .
scen:hasMemoryEffect a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:MemoryEffect ; rdfs:label "has memory effect" .
scen:hasClaimPromotionState a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:ClaimPromotionState ; rdfs:label "has claim-promotion state" .
scen:hasConsequenceModel a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:ConsequenceModel ; rdfs:label "has consequence model" .
scen:requiresAbstentionRule a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:AbstentionRule ; rdfs:label "requires abstention rule" .
scen:hasCounterfactualBranch a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:CounterfactualBranch ; rdfs:label "has counterfactual branch" .
scen:hasScenarioNonClaim a owl:ObjectProperty ; rdfs:domain scen:AdversarialScenario ; rdfs:range scen:ScenarioNonClaim ; rdfs:label "has scenario non-claim" .
scen:hasEvidenceEnvelope a owl:ObjectProperty ; rdfs:label "has evidence envelope" .
scen:hasRuntimeDecisionReceipt a owl:ObjectProperty ; rdfs:label "has runtime decision receipt" .
scen:mapsToTechniqueAnnotation a owl:ObjectProperty ; rdfs:label "maps to technique annotation" .
