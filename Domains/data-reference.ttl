@base <https://socioprophet.github.io/ontogenesis/> .
@prefix drm:   <https://socioprophet.github.io/ontogenesis/domains/data-reference#> .
@prefix cgrm:  <https://socioprophet.github.io/ontogenesis/domains/civic-governance#> .
@prefix cstack:<https://socioprophet.github.io/ontogenesis/civic-stack#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix dom:   <https://socioprophet.github.io/ontogenesis/domains/metadata#> .
@prefix party: <https://socioprophet.github.io/ontogenesis/domains/party#> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Domains/data-reference.ttl> a owl:Ontology ;
  dct:title "Domain — Data Reference Model" ;
  dct:description "DRM+ primitives for datasets, records, identifiers, provenance, consent, access basis, quality metrics, data contracts, and lineage events." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Domains/metadata.ttl>, <Domains/party-identity.ttl>, <Domains/civic-governance.ttl>, <Alignments/w3c-org.ttl> .

drm:Dataset a owl:Class ;
  rdfs:subClassOf cstack:RegulatedDataset, dom:Dataset, dcat:Dataset ;
  rdfs:label "Data reference dataset" .

drm:Record a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Record" .

drm:Identifier a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Identifier" .

drm:Provenance a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Provenance" .

drm:Consent a owl:Class ;
  rdfs:subClassOf cgrm:Policy ;
  rdfs:label "Consent" .

drm:AccessBasis a owl:Class ;
  rdfs:subClassOf cgrm:AccessBasis ;
  rdfs:label "Data access basis" .

drm:QualityMetric a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Data quality metric" .

drm:DataContract a owl:Class ;
  rdfs:subClassOf upper:Policy ;
  rdfs:label "Data contract" .

drm:DataAccessGrant a owl:Class ;
  rdfs:subClassOf upper:Policy ;
  rdfs:label "Data access grant" .

drm:LineageEvent a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Lineage event" .

drm:DataSubject a owl:Class ;
  rdfs:subClassOf party:Party ;
  rdfs:label "Data subject" .

drm:hasRecord a owl:ObjectProperty ;
  rdfs:domain drm:Dataset ;
  rdfs:range drm:Record ;
  rdfs:label "has record" .

drm:hasIdentifier a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range drm:Identifier ;
  rdfs:label "has identifier" .

drm:hasProvenance a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range drm:Provenance ;
  rdfs:label "has provenance" .

drm:hasConsent a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range drm:Consent ;
  rdfs:label "has consent" .

drm:hasAccessBasis a owl:ObjectProperty ;
  rdfs:subPropertyOf cgrm:hasAccessBasis ;
  rdfs:domain upper:Entity ;
  rdfs:range drm:AccessBasis ;
  rdfs:label "has data access basis" .

drm:hasQualityMetric a owl:ObjectProperty ;
  rdfs:domain drm:Dataset ;
  rdfs:range drm:QualityMetric ;
  rdfs:label "has quality metric" .

drm:governedByContract a owl:ObjectProperty ;
  rdfs:domain drm:Dataset ;
  rdfs:range drm:DataContract ;
  rdfs:label "governed by data contract" .

drm:grantsAccessTo a owl:ObjectProperty ;
  rdfs:domain drm:DataAccessGrant ;
  rdfs:range drm:Dataset ;
  rdfs:label "grants access to" .

drm:grantedToParty a owl:ObjectProperty ;
  rdfs:domain drm:DataAccessGrant ;
  rdfs:range party:Party ;
  rdfs:label "granted to party" .

drm:aboutSubject a owl:ObjectProperty ;
  rdfs:domain drm:Record ;
  rdfs:range drm:DataSubject ;
  rdfs:label "about subject" .

drm:wasGeneratedBy a owl:ObjectProperty ;
  rdfs:domain drm:Provenance ;
  rdfs:range prov:Activity ;
  rdfs:label "was generated by" .

drm:lineageActivity a owl:ObjectProperty ;
  rdfs:domain drm:LineageEvent ;
  rdfs:range prov:Activity ;
  rdfs:label "lineage activity" .

drm:identifierValue a owl:DatatypeProperty ;
  rdfs:domain drm:Identifier ;
  rdfs:range xsd:string ;
  rdfs:label "identifier value" .

drm:identifierSystem a owl:DatatypeProperty ;
  rdfs:domain drm:Identifier ;
  rdfs:range xsd:string ;
  rdfs:label "identifier system" .

drm:provenanceRef a owl:DatatypeProperty ;
  rdfs:subPropertyOf cstack:hasProvenanceRef ;
  rdfs:domain upper:Entity ;
  rdfs:range xsd:string ;
  rdfs:label "provenance reference" .

drm:qualityMetricCode a owl:DatatypeProperty ;
  rdfs:domain drm:QualityMetric ;
  rdfs:range xsd:string ;
  rdfs:label "quality metric code" .

drm:qualityMetricValue a owl:DatatypeProperty ;
  rdfs:domain drm:QualityMetric ;
  rdfs:range xsd:decimal ;
  rdfs:label "quality metric value" .

drm:dataClassification a owl:DatatypeProperty ;
  rdfs:domain drm:Dataset ;
  rdfs:range xsd:string ;
  rdfs:label "data classification" .

drm:retentionRule a owl:DatatypeProperty ;
  rdfs:domain drm:DataContract ;
  rdfs:range xsd:string ;
  rdfs:label "retention rule" .
