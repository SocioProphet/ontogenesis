@base <https://socioprophet.github.io/ontogenesis/> .
@prefix prm:   <https://socioprophet.github.io/ontogenesis/domains/performance-reference#> .
@prefix enrm:  <https://socioprophet.github.io/ontogenesis/domains/environment-reference#> .
@prefix cgrm:  <https://socioprophet.github.io/ontogenesis/domains/civic-governance#> .
@prefix cstack:<https://socioprophet.github.io/ontogenesis/civic-stack#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Domains/performance-reference.ttl> a owl:Ontology ;
  dct:title "Domain — Performance Reference Model" ;
  dct:description "PRM+ primitives for public-value outcomes, performance targets, indicators, observations, scorecards, thresholds, equity, resilience, environmental externality scoring, and evidence-backed delivery measurement." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Alignments/w3c-org.ttl>, <Domains/civic-governance.ttl>, <Domains/environment-reference.ttl> .

prm:Outcome a owl:Class ;
  rdfs:subClassOf cstack:CivicStackObject ;
  rdfs:label "Outcome" .

prm:PublicValueOutcome a owl:Class ;
  rdfs:subClassOf prm:Outcome ;
  rdfs:label "Public value outcome" .

prm:Indicator a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Indicator" .

prm:Target a owl:Class ;
  rdfs:subClassOf upper:Policy ;
  rdfs:label "Performance target" .

prm:Observation a owl:Class ;
  rdfs:subClassOf cstack:PerformanceObservation, sosa:Observation ;
  rdfs:label "Performance observation" .

prm:Scorecard a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Scorecard" .

prm:MetricContract a owl:Class ;
  rdfs:subClassOf upper:Policy ;
  rdfs:label "Metric contract" .

prm:EquityMetric a owl:Class ;
  rdfs:subClassOf prm:Indicator ;
  rdfs:label "Equity metric" .

prm:ResilienceMetric a owl:Class ;
  rdfs:subClassOf prm:Indicator ;
  rdfs:label "Resilience metric" .

prm:TrustMetric a owl:Class ;
  rdfs:subClassOf prm:Indicator ;
  rdfs:label "Trust metric" .

prm:EnvironmentalExternalityMetric a owl:Class ;
  rdfs:subClassOf prm:Indicator ;
  rdfs:label "Environmental externality metric" .

prm:AuditCompletenessMetric a owl:Class ;
  rdfs:subClassOf prm:Indicator ;
  rdfs:label "Audit completeness metric" .

prm:appliesTo a owl:ObjectProperty ;
  rdfs:domain prm:Target ;
  rdfs:range upper:Entity ;
  rdfs:label "applies to" .

prm:ownedBy a owl:ObjectProperty ;
  rdfs:domain prm:Target ;
  rdfs:range upper:Agent ;
  rdfs:label "owned by" .

prm:hasIndicator a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range prm:Indicator ;
  rdfs:label "has indicator" .

prm:hasTarget a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range prm:Target ;
  rdfs:label "has target" .

prm:hasObservation a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range prm:Observation ;
  rdfs:label "has observation" .

prm:hasScorecard a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range prm:Scorecard ;
  rdfs:label "has scorecard" .

prm:measuresOutcome a owl:ObjectProperty ;
  rdfs:domain prm:Indicator ;
  rdfs:range prm:Outcome ;
  rdfs:label "measures outcome" .

prm:derivedFromEvidence a owl:ObjectProperty ;
  rdfs:domain prm:Observation ;
  rdfs:range upper:Evidence ;
  rdfs:label "derived from evidence" .

prm:hasPolicyBasis a owl:ObjectProperty ;
  rdfs:domain prm:Target ;
  rdfs:range cgrm:Policy ;
  rdfs:label "has policy basis" .

prm:hasEnvironmentalFactor a owl:ObjectProperty ;
  rdfs:domain prm:Observation ;
  rdfs:range enrm:EnvironmentFactor ;
  rdfs:label "has environmental factor" .

prm:generatedByActivity a owl:ObjectProperty ;
  rdfs:domain prm:Observation ;
  rdfs:range prov:Activity ;
  rdfs:label "generated by activity" .

prm:indicatorCode a owl:DatatypeProperty ;
  rdfs:domain prm:Indicator ;
  rdfs:range xsd:string ;
  rdfs:label "indicator code" .

prm:threshold a owl:DatatypeProperty ;
  rdfs:domain prm:Target ;
  rdfs:range xsd:decimal ;
  rdfs:label "threshold" .

prm:value a owl:DatatypeProperty ;
  rdfs:domain prm:Observation ;
  rdfs:range xsd:decimal ;
  rdfs:label "value" .

prm:unit a owl:DatatypeProperty ;
  rdfs:domain prm:Indicator ;
  rdfs:range xsd:string ;
  rdfs:label "unit" .

prm:aggregationWindow a owl:DatatypeProperty ;
  rdfs:domain prm:MetricContract ;
  rdfs:range xsd:string ;
  rdfs:label "aggregation window" .

prm:confidence a owl:DatatypeProperty ;
  rdfs:domain prm:Observation ;
  rdfs:range xsd:decimal ;
  rdfs:label "confidence" .

prm:scoreValue a owl:DatatypeProperty ;
  rdfs:domain prm:Scorecard ;
  rdfs:range xsd:decimal ;
  rdfs:label "score value" .

prm:collectionMethod a owl:DatatypeProperty ;
  rdfs:domain prm:MetricContract ;
  rdfs:range xsd:string ;
  rdfs:label "collection method" .
