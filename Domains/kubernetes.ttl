@base <https://socioprophet.github.io/ontogenesis/> .
@prefix k8s: <https://socioprophet.github.io/ontogenesis/domains/kubernetes#> .
@prefix lower: <https://socioprophet.github.io/ontogenesis/lower#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Domains/kubernetes.ttl> a owl:Ontology ;
  dct:title "Domain — Kubernetes" ;
  dct:description "Kubernetes abstractions for reasoning over cluster resources used by Inception/Region/Macro profiles." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Lower/bindings-core.ttl> .

k8s:Deployment a owl:Class ; rdfs:subClassOf lower:K8sResource ; rdfs:label "Deployment" .
k8s:Service a owl:Class ; rdfs:subClassOf lower:K8sResource ; rdfs:label "Service" .
k8s:Ingress a owl:Class ; rdfs:subClassOf lower:K8sResource ; rdfs:label "Ingress" .
k8s:KnativeService a owl:Class ; rdfs:subClassOf lower:K8sResource ; rdfs:label "Knative Service" .
k8s:hasImage a owl:DatatypeProperty ; rdfs:domain k8s:Deployment ; rdfs:range xsd:string ; rdfs:label "has image" .
