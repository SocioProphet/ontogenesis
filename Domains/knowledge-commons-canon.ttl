<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-residue-theorem> a kcc:Formula ;
  rdfs:label '''residue theorem''' ;
  math:hasStatement '''∮_C f(z) dz = 2*pi*i * sum_k Res(f, z_k)''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-laplacian-in-spherical-coordinates> a kcc:Formula ;
  rdfs:label '''Laplacian in spherical coordinates''' ;
  math:hasStatement '''∇^2f = (1/r^2)*∂/∂r(r^2*∂f/∂r) + (1/(r^2*sin theta))*∂/∂theta(sin theta *∂f/∂theta) + (1/(r^2*sin^2 theta))*∂^2 f/∂phi^2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-spherical-harmonic-orthogonality> a kcc:Formula ;
  rdfs:label '''spherical harmonic orthogonality''' ;
  math:hasStatement '''∫ Y_l^m*(Omega) * Y_{l'}^{m'}(Omega) dOmega = delta_{ll'} * delta_{mm'}''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
