<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-riemann-tensor> a kcc:Formula ;
  rdfs:label '''Riemann tensor''' ;
  math:hasStatement '''R^lambda_{rho mu nu} = ∂_mu Gamma^lambda_{nu rho} - ∂_nu Gamma^lambda_{mu rho} + Gamma^lambda_{mu sigma}*Gamma^sigma_{nu rho} - Gamma^lambda_{nu sigma}*Gamma^sigma_{mu rho}''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-ricci-tensor> a kcc:GlossaryTerm ;
  skos:prefLabel '''Ricci tensor''' ;
  skos:definition '''R_{mu nu} = R^lambda_{mu lambda nu}''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:canonType '''definition''' ;
