<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-surjective-onto> a kcc:GlossaryTerm ;
  skos:prefLabel '''surjective (onto)''' ;
  skos:definition '''A function f: A → B is surjective if every element of B is f(a) for some a ∈ A.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-bijection> a kcc:GlossaryTerm ;
  skos:prefLabel '''bijection''' ;
  skos:definition '''A function that is both injective and surjective; establishes a one-to-one correspondence between domain and codomain.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-inverse-function> a kcc:GlossaryTerm ;
  skos:prefLabel '''inverse function''' ;
  skos:definition '''If f is bijective, its inverse f⁻¹ satisfies f⁻¹(f(x)) = x and f(f⁻¹(y)) = y for all x in the domain and y in the codomain.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-logarithm> a kcc:GlossaryTerm ;
  skos:prefLabel '''logarithm''' ;
