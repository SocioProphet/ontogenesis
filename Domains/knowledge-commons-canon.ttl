<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-entropy-from-partition-function> a kcc:Formula ;
  rdfs:label '''Entropy from partition function''' ;
  math:hasStatement '''S = k_B * ln(Q) + U/T''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-helmholtz-free-energy> a kcc:Formula ;
  rdfs:label '''Helmholtz free energy''' ;
  math:hasStatement '''A = -k_B * T * ln(Q)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
