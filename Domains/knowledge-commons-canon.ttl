<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-organic-reactions-and-mechanisms-sn2-mechanism> a kcc:GlossaryTerm ;
  skos:prefLabel '''SN2 mechanism''' ;
  skos:definition '''Bimolecular nucleophilic substitution proceeding through a backside-attack transition state with inversion of configuration; rate = k[Nu][substrate].''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-organic-reactions-and-mechanisms> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
