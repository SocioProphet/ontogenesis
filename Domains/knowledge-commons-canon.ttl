<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-analytical-chemistry-and-solution-equilibria-activity-concentration-relationship> a kcc:GlossaryTerm ;
  skos:prefLabel '''Activity-concentration relationship''' ;
  skos:definition '''a_i = gamma_i * c_i  (c in mol/L, relative to c^o = 1 M)''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-analytical-chemistry-and-solution-equilibria> ;
  kcc:canonType '''definition''' ;
