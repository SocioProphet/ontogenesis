  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-equilibrium-reaction-quotient-q> a kcc:GlossaryTerm ;
  skos:prefLabel '''reaction quotient (Q)''' ;
  skos:definition '''The ratio of product to reactant concentrations (or pressures) at any point; if Q < K reaction proceeds forward.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-equilibrium-le-chatelier-s-principle> a kcc:GlossaryTerm ;
  skos:prefLabel '''Le Chatelier's principle''' ;
  skos:definition '''A system at equilibrium responds to a stress by shifting in the direction that partially offsets that stress.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-equilibrium-solubility-product-k-sp> a kcc:GlossaryTerm ;
  skos:prefLabel '''solubility product (K_sp)''' ;
