<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-analytical-chemistry-and-solution-equilibria-chromatographic-resolution> a kcc:Formula ;
  rdfs:label '''Chromatographic resolution''' ;
  math:hasStatement '''R_s = (sqrt(N)/4) * (alpha - 1)/alpha * k'/(1 + k')  (fundamental resolution equation)''' ;
