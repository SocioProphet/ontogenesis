<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> a kcc:Topic ;
  skos:prefLabel '''Supply and Demand''' ;
  kcc:level '''intro''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-economics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> skos:scopeNote '''Law of demand and demand shifters; Law of supply and supply shifters; Market equilibrium and price determination; Price ceilings and price floors; Shifts vs. movements along curves; Consumer and producer surplus; Comparative statics; Markets for complements and substitutes''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-demand-curve> a kcc:GlossaryTerm ;
  skos:prefLabel '''demand curve''' ;
  skos:definition '''A schedule or curve showing the quantity of a good consumers are willing and able to purchase at each price, ceteris paribus; slopes downward due to the law of demand.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-supply-curve> a kcc:GlossaryTerm ;
  skos:prefLabel '''supply curve''' ;
  skos:definition '''A schedule or curve showing the quantity producers are willing and able to sell at each price, ceteris paribus; slopes upward due to increasing marginal costs.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-equilibrium-price> a kcc:GlossaryTerm ;
  skos:prefLabel '''equilibrium price''' ;
  skos:definition '''The price at which quantity demanded equals quantity supplied, clearing the market with no surplus or shortage.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-surplus-excess-supply> a kcc:GlossaryTerm ;
  skos:prefLabel '''surplus (excess supply)''' ;
  skos:definition '''A market condition in which quantity supplied exceeds quantity demanded at the prevailing price, placing downward pressure on price.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-shortage-excess-demand> a kcc:GlossaryTerm ;
  skos:prefLabel '''shortage (excess demand)''' ;
  skos:definition '''A market condition in which quantity demanded exceeds quantity supplied at the prevailing price, placing upward pressure on price.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-price-ceiling> a kcc:GlossaryTerm ;
  skos:prefLabel '''price ceiling''' ;
  skos:definition '''A legally imposed maximum price; causes a shortage when set below equilibrium price.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-price-floor> a kcc:GlossaryTerm ;
  skos:prefLabel '''price floor''' ;
  skos:definition '''A legally imposed minimum price; causes a surplus when set above equilibrium price.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-consumer-surplus> a kcc:GlossaryTerm ;
  skos:prefLabel '''consumer surplus''' ;
  skos:definition '''The difference between the maximum a consumer is willing to pay and the price actually paid, representing welfare gain to buyers.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-producer-surplus> a kcc:GlossaryTerm ;
  skos:prefLabel '''producer surplus''' ;
  skos:definition '''The difference between the price a producer receives and the minimum price at which the producer would supply the good.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-ceteris-paribus> a kcc:GlossaryTerm ;
  skos:prefLabel '''ceteris paribus''' ;
  skos:definition '''Latin for 'all else equal'; the assumption that all variables other than those under study remain constant.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-normal-good> a kcc:GlossaryTerm ;
  skos:prefLabel '''normal good''' ;
  skos:definition '''A good for which demand increases as consumer income rises.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-supply-and-demand-inferior-good> a kcc:GlossaryTerm ;
  skos:prefLabel '''inferior good''' ;
  skos:definition '''A good for which demand decreases as consumer income rises.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-market-equilibrium-condition> a kcc:Formula ;
  rdfs:label '''Market equilibrium condition''' ;
  math:hasStatement '''Q_d(P) = Q_s(P) ⟹ solve for P*''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-consumer-surplus-area> a kcc:Formula ;
  rdfs:label '''Consumer surplus (area)''' ;
  math:hasStatement '''CS = (1/2)(P_max - P*)(Q*)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-producer-surplus-area> a kcc:Formula ;
  rdfs:label '''Producer surplus (area)''' ;
  math:hasStatement '''PS = (1/2)(P* - P_min)(Q*)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-total-surplus> a kcc:Formula ;
  rdfs:label '''Total surplus''' ;
  math:hasStatement '''TS = CS + PS''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-law-of-demand> a kcc:Formula ;
  rdfs:label '''Law of demand''' ;
  math:hasStatement '''As price rises, quantity demanded falls, ceteris paribus (inverse relationship).''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-law-of-supply> a kcc:Formula ;
  rdfs:label '''Law of supply''' ;
  math:hasStatement '''As price rises, quantity supplied rises, ceteris paribus (direct relationship).''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-demand-shifters> a kcc:Formula ;
  rdfs:label '''Demand shifters''' ;
  math:hasStatement '''Demand shifts with changes in income, prices of related goods (substitutes/complements), tastes, expectations, and number of buyers.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-supply-shifters> a kcc:Formula ;
  rdfs:label '''Supply shifters''' ;
  math:hasStatement '''Supply shifts with changes in input prices, technology, expectations, number of sellers, and government taxes/subsidies.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-supply-and-demand-deadweight-loss-from-price-control> a kcc:Formula ;
  rdfs:label '''Deadweight loss from price control''' ;
  math:hasStatement '''DWL = (1/2)|Q_free - Q_controlled|(|P_s - P_d|)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-supply-and-demand> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> a kcc:Topic ;
  skos:prefLabel '''Elasticity''' ;
  kcc:level '''intro''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-economics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> skos:scopeNote '''Price elasticity of demand; Price elasticity of supply; Income elasticity of demand; Cross-price elasticity of demand; Determinants of elasticity; Elasticity and total revenue; Point vs. arc elasticity; Perfect elasticity and inelasticity''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-price-elasticity-of-demand-ped> a kcc:GlossaryTerm ;
  skos:prefLabel '''price elasticity of demand (PED)''' ;
  skos:definition '''The percentage change in quantity demanded divided by the percentage change in price; measures responsiveness of demand to price changes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-elastic-demand> a kcc:GlossaryTerm ;
  skos:prefLabel '''elastic demand''' ;
  skos:definition '''Demand is elastic when |PED| > 1; quantity demanded is highly responsive to price changes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-inelastic-demand> a kcc:GlossaryTerm ;
  skos:prefLabel '''inelastic demand''' ;
  skos:definition '''Demand is inelastic when |PED| < 1; quantity demanded is not very responsive to price changes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-unit-elastic> a kcc:GlossaryTerm ;
  skos:prefLabel '''unit elastic''' ;
  skos:definition '''Demand is unit elastic when |PED| = 1; total revenue is unchanged when price changes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-income-elasticity-of-demand-yed> a kcc:GlossaryTerm ;
  skos:prefLabel '''income elasticity of demand (YED)''' ;
  skos:definition '''The percentage change in quantity demanded divided by the percentage change in income; positive for normal goods, negative for inferior goods.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-cross-price-elasticity> a kcc:GlossaryTerm ;
  skos:prefLabel '''cross-price elasticity''' ;
  skos:definition '''The percentage change in quantity demanded of good X divided by the percentage change in price of good Y; positive for substitutes, negative for complements.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-price-elasticity-of-supply-pes> a kcc:GlossaryTerm ;
  skos:prefLabel '''price elasticity of supply (PES)''' ;
  skos:definition '''The percentage change in quantity supplied divided by the percentage change in price; always non-negative.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-perfectly-inelastic> a kcc:GlossaryTerm ;
  skos:prefLabel '''perfectly inelastic''' ;
  skos:definition '''Supply or demand is perfectly inelastic when elasticity equals zero; the curve is vertical.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-perfectly-elastic> a kcc:GlossaryTerm ;
  skos:prefLabel '''perfectly elastic''' ;
  skos:definition '''Supply or demand is perfectly elastic when elasticity is infinite; the curve is horizontal.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-elasticity-arc-elasticity> a kcc:GlossaryTerm ;
  skos:prefLabel '''arc elasticity''' ;
  skos:definition '''Elasticity calculated using midpoint (average) values of price and quantity over an interval, avoiding end-point sensitivity.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-price-elasticity-of-demand> a kcc:Formula ;
  rdfs:label '''Price elasticity of demand''' ;
  math:hasStatement '''E_d = (ΔQ/Q) / (ΔP/P) = (ΔQ/ΔP)(P/Q)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-midpoint-arc-elasticity-formula> a kcc:Formula ;
  rdfs:label '''Midpoint (arc) elasticity formula''' ;
  math:hasStatement '''E = [(Q2-Q1)/((Q1+Q2)/2)] / [(P2-P1)/((P1+P2)/2)]''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-income-elasticity-of-demand> a kcc:Formula ;
  rdfs:label '''Income elasticity of demand''' ;
  math:hasStatement '''YED = (%ΔQ_d) / (%ΔY)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-cross-price-elasticity> a kcc:Formula ;
  rdfs:label '''Cross-price elasticity''' ;
  math:hasStatement '''XED = (%ΔQ_x) / (%ΔP_y)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-total-revenue-and-elasticity> a kcc:Formula ;
  rdfs:label '''Total revenue and elasticity''' ;
  math:hasStatement '''TR = P × Q; if |E_d| > 1, price ↑ ⟹ TR ↓; if |E_d| < 1, price ↑ ⟹ TR ↑''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-elasticity-of-linear-demand-curve> a kcc:Formula ;
  rdfs:label '''Elasticity of linear demand curve''' ;
  math:hasStatement '''E_d = -(b)(P/Q) where Q = a - bP''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-determinants-of-ped> a kcc:Formula ;
  rdfs:label '''Determinants of PED''' ;
  math:hasStatement '''Demand is more elastic when: more close substitutes exist, the good is a luxury, it represents a large budget share, or the time horizon is longer.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-elasticity-tax-incidence-and-elasticity> a kcc:Formula ;
  rdfs:label '''Tax incidence and elasticity''' ;
  math:hasStatement '''The more inelastic side of the market bears a larger share of a tax burden.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-elasticity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> a kcc:Topic ;
  skos:prefLabel '''Consumer Theory''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-economics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> skos:scopeNote '''Utility functions and indifference curves; Budget constraint; Utility maximization (tangency condition); Marshallian and Hicksian demand; Income and substitution effects; Slutsky equation; Revealed preference; Intertemporal choice; Expected utility and risk''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-utility> a kcc:GlossaryTerm ;
  skos:prefLabel '''utility''' ;
  skos:definition '''A numerical representation of a consumer's preferences over bundles of goods; higher utility indicates preferred bundles.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-marginal-utility-mu> a kcc:GlossaryTerm ;
  skos:prefLabel '''marginal utility (MU)''' ;
  skos:definition '''The additional utility gained from consuming one more unit of a good, holding other consumption constant; typically diminishing.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-indifference-curve> a kcc:GlossaryTerm ;
  skos:prefLabel '''indifference curve''' ;
  skos:definition '''A curve showing all combinations of goods that yield equal utility; slopes downward and is convex to the origin under standard assumptions.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-marginal-rate-of-substitution-mrs> a kcc:GlossaryTerm ;
  skos:prefLabel '''marginal rate of substitution (MRS)''' ;
  skos:definition '''The rate at which a consumer is willing to trade one good for another while remaining on the same indifference curve; equals -MU_x/MU_y.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-budget-constraint> a kcc:GlossaryTerm ;
  skos:prefLabel '''budget constraint''' ;
  skos:definition '''The set of consumption bundles affordable at given income and prices: P_x·X + P_y·Y = I.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-marshallian-demand> a kcc:GlossaryTerm ;
  skos:prefLabel '''Marshallian demand''' ;
  skos:definition '''Ordinary (uncompensated) demand that maximizes utility subject to the budget constraint; depends on prices and income.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-hicksian-demand> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hicksian demand''' ;
  skos:definition '''Compensated demand that minimizes expenditure while achieving a given utility level; isolates the pure substitution effect.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-substitution-effect> a kcc:GlossaryTerm ;
  skos:prefLabel '''substitution effect''' ;
  skos:definition '''The change in quantity demanded due solely to the change in relative prices, holding utility constant.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-income-effect> a kcc:GlossaryTerm ;
  skos:prefLabel '''income effect''' ;
  skos:definition '''The change in quantity demanded due to the change in real purchasing power when a price changes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-slutsky-equation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Slutsky equation''' ;
  skos:definition '''Decomposes the total price effect into substitution and income effects: ∂x/∂p = ∂h/∂p - x·(∂x/∂I).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-giffen-good> a kcc:GlossaryTerm ;
  skos:prefLabel '''Giffen good''' ;
  skos:definition '''An inferior good with such a large income effect that demand curves upward; quantity demanded rises when price rises.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-expenditure-function> a kcc:GlossaryTerm ;
  skos:prefLabel '''expenditure function''' ;
  skos:definition '''The minimum expenditure required to achieve a given utility level at given prices: e(p,u).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-consumer-theory-indirect-utility-function> a kcc:GlossaryTerm ;
  skos:prefLabel '''indirect utility function''' ;
  skos:definition '''The maximum utility achievable given prices and income: V(p,I).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-utility-maximization-tangency> a kcc:Formula ;
  rdfs:label '''Utility maximization (tangency)''' ;
  math:hasStatement '''MU_x/P_x = MU_y/P_y  ⟺  MRS_{xy} = P_x/P_y''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-budget-constraint> a kcc:Formula ;
  rdfs:label '''Budget constraint''' ;
  math:hasStatement '''P_x · X + P_y · Y = I''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-lagrangian-for-consumer-problem> a kcc:Formula ;
  rdfs:label '''Lagrangian for consumer problem''' ;
  math:hasStatement '''max U(x,y) s.t. P_x·x + P_y·y = I; ℒ = U(x,y) - λ(P_x·x + P_y·y - I)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-slutsky-equation> a kcc:Formula ;
  rdfs:label '''Slutsky equation''' ;
  math:hasStatement '''∂x^m/∂p_x = ∂x^h/∂p_x - x·(∂x^m/∂I)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-roy-s-identity> a kcc:Formula ;
  rdfs:label '''Roy's identity''' ;
  math:hasStatement '''x_i^m(p,I) = -[∂V/∂p_i] / [∂V/∂I]''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-shephard-s-lemma> a kcc:Formula ;
  rdfs:label '''Shephard's lemma''' ;
  math:hasStatement '''x_i^h(p,u) = ∂e(p,u)/∂p_i''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-mrs-for-cobb-douglas-u-x-y> a kcc:Formula ;
  rdfs:label '''MRS for Cobb-Douglas U = x^α·y^β''' ;
  math:hasStatement '''MRS = (αy)/(βx)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-law-of-diminishing-marginal-utility> a kcc:Formula ;
  rdfs:label '''Law of diminishing marginal utility''' ;
  math:hasStatement '''As consumption of a good increases, the marginal utility from each additional unit eventually declines.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-expected-utility-von-neumann-morgenstern> a kcc:Formula ;
  rdfs:label '''Expected utility (von Neumann-Morgenstern)''' ;
  math:hasStatement '''EU = Σ π_i · U(w_i) where π_i is probability of outcome i''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-consumer-theory-risk-aversion-condition> a kcc:Formula ;
  rdfs:label '''Risk aversion condition''' ;
  math:hasStatement '''A consumer is risk-averse iff U''(w) < 0 (concave utility function).''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-consumer-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> a kcc:Topic ;
  skos:prefLabel '''Producer Theory: Production and Costs''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-economics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> skos:scopeNote '''Production function and isoquants; Marginal and average products; Returns to scale; Cost minimization and input choice; Short-run vs. long-run costs; Total, average, and marginal cost; Economies of scale and scope; Duality: cost and production; Profit maximization''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-production-function> a kcc:GlossaryTerm ;
  skos:prefLabel '''production function''' ;
  skos:definition '''A function Q = f(K,L) relating the quantity of output to the quantities of capital and labor (or other inputs) used.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-marginal-product-of-labor-mpl> a kcc:GlossaryTerm ;
  skos:prefLabel '''marginal product of labor (MPL)''' ;
  skos:definition '''The additional output produced by employing one more unit of labor, holding capital constant: MPL = ∂Q/∂L.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-marginal-rate-of-technical-substitution-mrts> a kcc:GlossaryTerm ;
  skos:prefLabel '''marginal rate of technical substitution (MRTS)''' ;
  skos:definition '''The rate at which capital can be substituted for labor while holding output constant; equals MPL/MPK along an isoquant.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-isoquant> a kcc:GlossaryTerm ;
  skos:prefLabel '''isoquant''' ;
  skos:definition '''A curve showing all combinations of inputs that produce a given quantity of output.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-returns-to-scale> a kcc:GlossaryTerm ;
  skos:prefLabel '''returns to scale''' ;
  skos:definition '''How output changes when all inputs are scaled proportionally: constant (CRS), increasing (IRS), or decreasing (DRS).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-total-cost-tc> a kcc:GlossaryTerm ;
  skos:prefLabel '''total cost (TC)''' ;
  skos:definition '''The sum of all costs incurred in production: TC = TFC + TVC.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-average-total-cost-atc> a kcc:GlossaryTerm ;
  skos:prefLabel '''average total cost (ATC)''' ;
  skos:definition '''Total cost per unit of output: ATC = TC/Q.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-marginal-cost-mc> a kcc:GlossaryTerm ;
  skos:prefLabel '''marginal cost (MC)''' ;
  skos:definition '''The incremental cost of producing one more unit of output: MC = ΔTC/ΔQ = dTC/dQ.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-sunk-cost> a kcc:GlossaryTerm ;
  skos:prefLabel '''sunk cost''' ;
  skos:definition '''A cost already incurred and unrecoverable regardless of future decisions; should not influence forward-looking choices.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-economies-of-scale> a kcc:GlossaryTerm ;
  skos:prefLabel '''economies of scale''' ;
  skos:definition '''A situation in which long-run average cost declines as output increases.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-diseconomies-of-scale> a kcc:GlossaryTerm ;
  skos:prefLabel '''diseconomies of scale''' ;
  skos:definition '''A situation in which long-run average cost rises as output increases.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-economies-of-scope> a kcc:GlossaryTerm ;
  skos:prefLabel '''economies of scope''' ;
  skos:definition '''Cost savings achieved when it is cheaper to produce two goods jointly than separately: C(Q1,Q2) < C(Q1,0) + C(0,Q2).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-economics-producer-theory-production-and-costs-isocost-line> a kcc:GlossaryTerm ;
  skos:prefLabel '''isocost line''' ;
  skos:definition '''A line showing all combinations of inputs that can be hired at a given total expenditure: wL + rK = C.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-cost-minimization-condition> a kcc:Formula ;
  rdfs:label '''Cost minimization condition''' ;
  math:hasStatement '''MRTS = w/r  ⟺  MPL/MPK = w/r''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-isocost-line> a kcc:Formula ;
  rdfs:label '''Isocost line''' ;
  math:hasStatement '''wL + rK = C  ⟹  K = C/r - (w/r)L''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-cobb-douglas-production-function> a kcc:Formula ;
  rdfs:label '''Cobb-Douglas production function''' ;
  math:hasStatement '''Q = A·K^α·L^β; CRS if α+β=1, IRS if α+β>1, DRS if α+β<1''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-marginal-product> a kcc:Formula ;
  rdfs:label '''Marginal product''' ;
  math:hasStatement '''MPL = ∂Q/∂L;  MPK = ∂Q/∂K''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-profit-maximization-condition> a kcc:Formula ;
  rdfs:label '''Profit maximization condition''' ;
  math:hasStatement '''π = TR - TC;  dπ/dQ = 0  ⟹  MR = MC''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-short-run-total-cost> a kcc:Formula ;
  rdfs:label '''Short-run total cost''' ;
  math:hasStatement '''STC(Q) = TFC + TVC(Q)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-relationship-between-atc-and-mc> a kcc:Formula ;
  rdfs:label '''Relationship between ATC and MC''' ;
  math:hasStatement '''MC < ATC ⟹ ATC is falling; MC > ATC ⟹ ATC is rising; MC = ATC at minimum ATC.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-long-run-average-cost-envelope> a kcc:Formula ;
  rdfs:label '''Long-run average cost envelope''' ;
  math:hasStatement '''LRAC is the lower envelope of all SRAC curves; each SRAC is tangent to LRAC at one output level.''' ;
  kcc:canonType '''principle''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-shephard-s-lemma-cost> a kcc:Formula ;
  rdfs:label '''Shephard's lemma (cost)''' ;
  math:hasStatement '''Conditional input demand: x_i = ∂C(w,Q)/∂w_i''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-economics-producer-theory-production-and-costs-economies-of-scale-index> a kcc:Formula ;
  rdfs:label '''Economies of scale index''' ;
  math:hasStatement '''S = AC/MC; S>1 ⟹ economies of scale, S<1 ⟹ diseconomies''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-producer-theory-production-and-costs> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-economics-market-structures> a kcc:Topic ;
  skos:prefLabel '''Market Structures''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-economics> ;
