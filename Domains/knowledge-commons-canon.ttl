<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-electrochemistry-gibbs-free-energy-and-cell-potential> a kcc:Formula ;
  rdfs:label '''Gibbs free energy and cell potential''' ;
  math:hasStatement '''delta_G^o = -n*F*E^o_cell''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-electrochemistry> ;
