  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-gauss-s-law-integral> a kcc:Formula ;
  rdfs:label '''Gauss's law (integral)''' ;
  math:hasStatement '''∮ E · dA = Q_enc / epsilon_0''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-gauss-s-law-for-magnetism> a kcc:Formula ;
  rdfs:label '''Gauss's law for magnetism''' ;
  math:hasStatement '''∮ B · dA = 0''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
