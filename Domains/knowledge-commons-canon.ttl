<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-gases-and-kinetic-molecular-theory-compressibility-factor> a kcc:GlossaryTerm ;
  skos:prefLabel '''Compressibility factor''' ;
  skos:definition '''Z = PV / (nRT)''' ;
