<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-convolution-theorem> a kcc:Formula ;
  rdfs:label '''convolution theorem''' ;
  math:hasStatement '''FT[f*g] = f̃ * g̃  (pointwise product)''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
