<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-helmholtz-free-energy-from-z> a kcc:Formula ;
  rdfs:label '''Helmholtz free energy from Z''' ;
  math:hasStatement '''F = -k_B*T * ln(Z)''' ;
