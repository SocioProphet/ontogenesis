<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-analytical-mechanics-lagrangian-and-hamiltonian-euler-lagrange-equation> a kcc:Formula ;
  rdfs:label '''Euler-Lagrange equation''' ;
  math:hasStatement '''d/dt(∂L/∂q̇_i) - ∂L/∂q_i = 0''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
