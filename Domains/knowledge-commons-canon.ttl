<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-analytical-chemistry-and-solution-equilibria-ionic-strength> a kcc:GlossaryTerm ;
  skos:prefLabel '''Ionic strength''' ;
  skos:definition '''I = (1/2) * sum_i(c_i * z_i^2)''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-analytical-chemistry-and-solution-equilibria> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
