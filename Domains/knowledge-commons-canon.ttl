<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-planck-distribution-mean-photon-occupation> a kcc:Formula ;
  rdfs:label '''Planck distribution (mean photon occupation)''' ;
  math:hasStatement '''n_BE(omega) = 1 / (exp(ℏ*omega/(k_B*T)) - 1)''' ;
