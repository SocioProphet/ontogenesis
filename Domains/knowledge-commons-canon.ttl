<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-stefan-boltzmann-law> a kcc:Formula ;
  rdfs:label '''Stefan-Boltzmann law''' ;
  math:hasStatement '''P/A = sigma_SB * T^4;  sigma_SB = 2*pi^5*k_B^4 / (15*c^2*h^3)''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
