<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-atomic-structure-and-quantum-chemistry-hydrogen-atom-energy-levels> a kcc:Formula ;
  rdfs:label '''Hydrogen atom energy levels''' ;
  math:hasStatement '''E_n = -13.6 eV / n^2 = -R_H * h * c / n^2''' ;
  kcc:canonType '''equation''' ;
