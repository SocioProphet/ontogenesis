<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-schwarzschild-metric> a kcc:Formula ;
  rdfs:label '''Schwarzschild metric''' ;
  math:hasStatement '''ds^2 = -(1 - r_s/r)c^2 dt^2 + (1 - r_s/r)^{-1} dr^2 + r^2 dOmega^2;  r_s = 2GM/c^2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-friedmann-equation-flat> a kcc:Formula ;
  rdfs:label '''Friedmann equation (flat)''' ;
  math:hasStatement '''H^2 = (8*pi*G/3)*rho - k*c^2/a^2 + Lambda*c^2/3''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-linearized-gravitational-wave-equation> a kcc:Formula ;
  rdfs:label '''linearized gravitational wave equation''' ;
  math:hasStatement '''Box h_{mu nu} = -16*pi*G/c^4 * T_{mu nu}  (Lorenz gauge)''' ;
  kcc:canonType '''equation''' ;
