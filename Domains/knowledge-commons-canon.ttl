<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-clausius-inequality> a kcc:Formula ;
  rdfs:label '''Clausius inequality''' ;
  math:hasStatement '''dS >= delta Q / T  (equality for reversible process)''' ;
  kcc:canonType '''law''' ;
