<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-atomic-structure-and-quantum-chemistry-heisenberg-uncertainty-principle> a kcc:Formula ;
  rdfs:label '''Heisenberg uncertainty principle''' ;
  math:hasStatement '''delta_x * delta_p >= h_bar / 2''' ;
