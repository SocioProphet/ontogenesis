<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-atomic-structure-and-quantum-chemistry-rydberg-formula-for-hydrogen> a kcc:Formula ;
  rdfs:label '''Rydberg formula for hydrogen''' ;
  math:hasStatement '''1/lambda = R_H * (1/n_1^2 - 1/n_2^2)  where R_H = 1.097e7 m^-1''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-atomic-structure-and-quantum-chemistry> ;
