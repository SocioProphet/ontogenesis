  skos:prefLabel '''SN1 mechanism''' ;
  skos:definition '''Unimolecular nucleophilic substitution through a carbocation intermediate; rate depends only on substrate concentration; can give racemization.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-organic-reactions-and-mechanisms> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
