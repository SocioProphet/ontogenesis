<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-green-s-function-equation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Green's function equation''' ;
  skos:definition '''L_x G(x,x') = delta(x - x');  y(x) = ∫ G(x,x')*f(x') dx'''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
