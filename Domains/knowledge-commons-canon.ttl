<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-poynting-vector> a kcc:Formula ;
  rdfs:label '''Poynting vector''' ;
  math:hasStatement '''S = (1/mu_0) * E × B''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
