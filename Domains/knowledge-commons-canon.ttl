<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-thermodynamics-classical-adiabatic-process-ideal-gas> a kcc:Formula ;
  rdfs:label '''adiabatic process (ideal gas)''' ;
  math:hasStatement '''P*V^gamma = constant;  T*V^(gamma-1) = constant;  gamma = C_P/C_V''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-thermodynamics-classical> ;
