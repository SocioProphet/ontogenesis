<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-kinetics-michaelis-menten-kinetics> a kcc:GlossaryTerm ;
  skos:prefLabel '''Michaelis-Menten kinetics''' ;
  skos:definition '''A kinetic model for enzyme catalysis: v = V_max[S] / (K_M + [S]), where K_M is the Michaelis constant.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-kinetics-steady-state-approximation> a kcc:GlossaryTerm ;
  skos:prefLabel '''steady-state approximation''' ;
  skos:definition '''The assumption that the concentration of a reactive intermediate remains nearly constant throughout the reaction.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-generic-rate-law> a kcc:Formula ;
  rdfs:label '''Generic rate law''' ;
  math:hasStatement '''rate = k[A]^m [B]^n''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-first-order-integrated-rate-law> a kcc:Formula ;
  rdfs:label '''First-order integrated rate law''' ;
  math:hasStatement '''ln[A]_t = ln[A]_0 - k*t  =>  [A]_t = [A]_0 * exp(-k*t)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-first-order-half-life> a kcc:Formula ;
  rdfs:label '''First-order half-life''' ;
  math:hasStatement '''t_1/2 = ln(2) / k = 0.6931 / k''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-second-order-integrated-rate-law-one-reactant> a kcc:Formula ;
  rdfs:label '''Second-order integrated rate law (one reactant)''' ;
  math:hasStatement '''1/[A]_t = 1/[A]_0 + k*t''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-second-order-half-life> a kcc:Formula ;
  rdfs:label '''Second-order half-life''' ;
  math:hasStatement '''t_1/2 = 1 / (k[A]_0)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-zeroth-order-integrated-rate-law> a kcc:Formula ;
  rdfs:label '''Zeroth-order integrated rate law''' ;
  math:hasStatement '''[A]_t = [A]_0 - k*t''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-arrhenius-equation> a kcc:Formula ;
  rdfs:label '''Arrhenius equation''' ;
  math:hasStatement '''k = A * exp(-E_a / (R*T))''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-arrhenius-linearized> a kcc:Formula ;
  rdfs:label '''Arrhenius linearized''' ;
  math:hasStatement '''ln(k) = ln(A) - E_a/(R*T)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-eyring-transition-state-theory-equation> a kcc:Formula ;
  rdfs:label '''Eyring (transition state theory) equation''' ;
  math:hasStatement '''k = (k_B * T / h) * exp(-delta_G_dagger / (R*T))''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-michaelis-menten-equation> a kcc:Formula ;
  rdfs:label '''Michaelis-Menten equation''' ;
  math:hasStatement '''v = V_max * [S] / (K_M + [S])''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-kinetics-lineweaver-burk-linearization> a kcc:Formula ;
  rdfs:label '''Lineweaver-Burk linearization''' ;
  math:hasStatement '''1/v = (K_M/V_max)*(1/[S]) + 1/V_max''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-kinetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
