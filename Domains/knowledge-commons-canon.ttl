<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-maxwell-relations-from-f> a kcc:Formula ;
  rdfs:label '''Maxwell relations (from F)''' ;
  math:hasStatement '''(∂S/∂V)_T = (∂P/∂T)_V''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-grand-partition-function> a kcc:Formula ;
  rdfs:label '''grand partition function''' ;
  math:hasStatement '''Z_G = sum_{N,i} exp(-beta*(E_{N,i} - mu*N))''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
