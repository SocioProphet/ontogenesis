<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-special-relativity-relativistic-energy> a kcc:Formula ;
  rdfs:label '''relativistic energy''' ;
  math:hasStatement '''E = gamma * m * c^2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-special-relativity> ;
