<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-quadrupole-radiation-formula> a kcc:Formula ;
  rdfs:label '''quadrupole radiation formula''' ;
  math:hasStatement '''P_GW = (G/(5*c^5)) * <d^3 Q_{ij}/dt^3 * d^3 Q^{ij}/dt^3>''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
