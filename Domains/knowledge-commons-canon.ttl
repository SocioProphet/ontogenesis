<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-coordination-chemistry-and-inorganic-chemistry-crystal-field-splitting-tetrahedral> a kcc:Formula ;
  rdfs:label '''Crystal field splitting (tetrahedral)''' ;
  math:hasStatement '''Delta_tet = (4/9) * Delta_oct (for same metal and ligands)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-coordination-chemistry-and-inorganic-chemistry> ;
