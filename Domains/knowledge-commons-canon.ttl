<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-analytical-mechanics-lagrangian-and-hamiltonian-fundamental-poisson-brackets> a kcc:Formula ;
  rdfs:label '''fundamental Poisson brackets''' ;
  math:hasStatement '''{q_i, p_j} = delta_ij,  {q_i,q_j} = 0,  {p_i,p_j} = 0''' ;
