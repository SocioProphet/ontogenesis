<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-position-momentum-uncertainty> a kcc:Formula ;
  rdfs:label '''position-momentum uncertainty''' ;
  math:hasStatement '''sigma_x * sigma_p >= ℏ/2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
