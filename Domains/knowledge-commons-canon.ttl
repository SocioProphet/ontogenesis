<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-astrophysics-and-cosmology-frw-metric-flat> a kcc:Formula ;
  rdfs:label '''FRW metric (flat)''' ;
  math:hasStatement '''ds^2 = -c^2 dt^2 + a(t)^2 (dr^2 + r^2 dOmega^2)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-astrophysics-and-cosmology> ;
