<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-maxwell-s-equations-differential-form> a kcc:Formula ;
  rdfs:label '''Maxwell's equations (differential form)''' ;
  math:hasStatement '''∇·E = rho/epsilon_0;  ∇·B = 0;  ∇×E = -∂B/∂t;  ∇×B = mu_0*(J + epsilon_0*∂E/∂t)''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-biot-savart-law> a kcc:Formula ;
  rdfs:label '''Biot-Savart law''' ;
  math:hasStatement '''dB = (mu_0/(4*pi)) * I*(dl × r̂)/r^2''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
