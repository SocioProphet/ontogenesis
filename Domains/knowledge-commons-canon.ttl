<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-optics-and-waves-doppler-shift-non-relativistic> a kcc:Formula ;
  rdfs:label '''Doppler shift (non-relativistic)''' ;
