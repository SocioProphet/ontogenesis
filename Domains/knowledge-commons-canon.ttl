  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-classical-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-classical-mechanics-kinematic-equation-displacement> a kcc:Formula ;
  rdfs:label '''kinematic equation (displacement)''' ;
  math:hasStatement '''x = x_0 + v_0*t + (1/2)*a*t^2''' ;
  kcc:canonType '''equation''' ;
