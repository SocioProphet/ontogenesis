<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-analytical-mechanics-lagrangian-and-hamiltonian-definition-of-conjugate-momentum> a kcc:GlossaryTerm ;
  skos:prefLabel '''definition of conjugate momentum''' ;
  skos:definition '''p_i = ∂L/∂q̇_i''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
