<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-bose-einstein-distribution> a kcc:Formula ;
  rdfs:label '''Bose-Einstein distribution''' ;
  math:hasStatement '''f_BE(epsilon) = 1 / (exp(beta*(epsilon - mu)) - 1)''' ;
