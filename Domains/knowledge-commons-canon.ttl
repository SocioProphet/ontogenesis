  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-classical-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-classical-mechanics-continuity-equation-fluids> a kcc:Formula ;
  rdfs:label '''continuity equation (fluids)''' ;
  math:hasStatement '''A_1 * v_1 = A_2 * v_2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-classical-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> a kcc:Topic ;
  skos:prefLabel '''Analytical Mechanics (Lagrangian and Hamiltonian)''' ;
  kcc:level '''graduate''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> skos:scopeNote '''generalized coordinates and constraints; principle of stationary action; Euler-Lagrange equations; cyclic coordinates and conservation laws; Legendre transformation and the Hamiltonian; Hamilton's equations of motion; Poisson brackets; canonical transformations; Hamilton-Jacobi theory; action-angle variables and adiabatic invariants''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-generalized-coordinates> a kcc:GlossaryTerm ;
  skos:prefLabel '''generalized coordinates''' ;
  skos:definition '''Any set of independent parameters q_i that uniquely specifies the configuration of a system, not necessarily Cartesian.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-holonomic-constraint> a kcc:GlossaryTerm ;
  skos:prefLabel '''holonomic constraint''' ;
  skos:definition '''A constraint expressible as an algebraic relation among the generalized coordinates (and possibly time): f(q_1,...,q_n,t) = 0.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-lagrangian> a kcc:GlossaryTerm ;
  skos:prefLabel '''Lagrangian''' ;
  skos:definition '''The function L = T - V (kinetic minus potential energy) whose integral over time, the action, is stationary along the physical trajectory.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-action> a kcc:GlossaryTerm ;
  skos:prefLabel '''action''' ;
  skos:definition '''The functional S[q] = integral(L(q, dq/dt, t) dt) whose stationary paths (δS = 0) yield the equations of motion.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-euler-lagrange-equation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Euler-Lagrange equation''' ;
  skos:definition '''The differential equation d/dt(∂L/∂q̇_i) - ∂L/∂q_i = 0 that a path must satisfy to render the action stationary.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-cyclic-coordinate> a kcc:GlossaryTerm ;
  skos:prefLabel '''cyclic coordinate''' ;
  skos:definition '''A generalized coordinate q_i that does not appear explicitly in L (only q̇_i does), implying its conjugate momentum p_i = ∂L/∂q̇_i is conserved.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-conjugate-momentum> a kcc:GlossaryTerm ;
  skos:prefLabel '''conjugate momentum''' ;
  skos:definition '''The quantity p_i = ∂L/∂q̇_i canonically paired with the generalized coordinate q_i; reduces to ordinary momentum in Cartesian coordinates.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-hamiltonian> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hamiltonian''' ;
  skos:definition '''H(q,p,t) = sum_i(p_i * q̇_i) - L, the Legendre transform of the Lagrangian; equals the total energy when L has no explicit time dependence and constraints are scleronomic.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-legendre-transformation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Legendre transformation''' ;
  skos:definition '''A mathematical transform that switches between functions of complementary variables; converts L(q,q̇) to H(q,p).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-canonical-transformation> a kcc:GlossaryTerm ;
  skos:prefLabel '''canonical transformation''' ;
  skos:definition '''A change of phase-space variables (q,p) → (Q,P) that preserves the form of Hamilton's equations, i.e., preserves the Poisson bracket structure.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-poisson-bracket> a kcc:GlossaryTerm ;
  skos:prefLabel '''Poisson bracket''' ;
  skos:definition '''The bilinear operation {f,g} = sum_i(∂f/∂q_i * ∂g/∂p_i - ∂f/∂p_i * ∂g/∂q_i) measuring how rapidly one observable changes along the flow generated by another.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-action-angle-variables> a kcc:GlossaryTerm ;
  skos:prefLabel '''action-angle variables''' ;
  skos:definition '''Canonical variables (J, θ) where J is the action integral (adiabatic invariant) and θ advances uniformly in time; natural for integrable systems.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-analytical-mechanics-lagrangian-and-hamiltonian-adiabatic-invariant> a kcc:GlossaryTerm ;
  skos:prefLabel '''adiabatic invariant''' ;
  skos:definition '''A quantity J = (1/2π) * ∮ p dq that is approximately conserved when system parameters change slowly compared to the oscillation period.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-analytical-mechanics-lagrangian-and-hamiltonian-principle-of-stationary-action> a kcc:Formula ;
  rdfs:label '''principle of stationary action''' ;
  math:hasStatement '''delta S = delta integral(L dt) = 0''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-analytical-mechanics-lagrangian-and-hamiltonian> ;
