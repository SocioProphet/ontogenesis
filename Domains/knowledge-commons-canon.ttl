<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-stokes-theorem> a kcc:Formula ;
  rdfs:label '''Stokes' theorem''' ;
  math:hasStatement '''∮_C F · dl = ∫∫_S (∇×F) · dA''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-gradient-theorem-path-independence> a kcc:Formula ;
  rdfs:label '''gradient theorem (path independence)''' ;
  math:hasStatement '''∫_A^B (∇f) · dl = f(B) - f(A)''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
