<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-pauli-matrices> a kcc:GlossaryTerm ;
  skos:prefLabel '''Pauli matrices''' ;
  skos:definition '''σ_x=[[0,1],[1,0]]; σ_y=[[0,-i],[i,0]]; σ_z=[[1,0],[0,-1]]''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
