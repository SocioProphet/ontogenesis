<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-precalculus-and-functions-sum-of-geometric-series> a math:Equation ;
  rdfs:label '''Sum of geometric series''' ;
  math:hasStatement '''S_n = a(1 - r^n)/(1 - r); infinite sum S = a/(1-r) for |r| < 1''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-precalculus-and-functions-sum-of-arithmetic-series> a math:Equation ;
  rdfs:label '''Sum of arithmetic series''' ;
  math:hasStatement '''S_n = n(a_1 + a_n)/2 = n(2a_1 + (n-1)d)/2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-precalculus-and-functions-euler-s-formula> a math:Equation ;
