<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-time-independent-schr-dinger-equation> a kcc:Formula ;
  rdfs:label '''time-independent Schrödinger equation''' ;
  math:hasStatement '''Ĥψ = Eψ  →  (-ℏ^2/(2m) ∇^2 + V(r))ψ(r) = E*ψ(r)''' ;
  kcc:canonType '''equation''' ;
