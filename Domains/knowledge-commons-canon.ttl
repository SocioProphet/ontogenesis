<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-thermodynamics-classical-first-law-of-thermodynamics> a kcc:Formula ;
  rdfs:label '''first law of thermodynamics''' ;
  math:hasStatement '''Delta U = Q - W  (Q = heat in, W = work done BY system)''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-thermodynamics-classical> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-thermodynamics-classical-second-law-of-thermodynamics> a kcc:Formula ;
  rdfs:label '''second law of thermodynamics''' ;
  math:hasStatement '''dS >= delta Q / T;  Delta S_universe >= 0 for any process''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-thermodynamics-classical> ;
