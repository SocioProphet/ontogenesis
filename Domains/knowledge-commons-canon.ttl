<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-henderson-hasselbalch-biological-buffers> a kcc:Formula ;
  rdfs:label '''Henderson-Hasselbalch (biological buffers)''' ;
  math:hasStatement '''pH = pK_a + log([A-]/[HA])  (e.g. bicarbonate: pK_a1 = 6.1 at 37 degrees C)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
