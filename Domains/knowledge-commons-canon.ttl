<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-equilibrium-equilibrium-constant-k> a kcc:GlossaryTerm ;
  skos:prefLabel '''equilibrium constant (K)''' ;
