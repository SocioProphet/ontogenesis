<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-classical-mechanics-rotational-kinetic-energy> a kcc:Formula ;
  rdfs:label '''rotational kinetic energy''' ;
  math:hasStatement '''KE_rot = (1/2) * I * omega^2''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-classical-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-classical-mechanics-simple-harmonic-oscillator-frequency> a kcc:Formula ;
  rdfs:label '''simple harmonic oscillator frequency''' ;
