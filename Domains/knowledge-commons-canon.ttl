  skos:prefLabel '''VSEPR''' ;
  skos:definition '''Valence Shell Electron Pair Repulsion theory; molecular geometry determined by minimizing repulsion between electron domains around the central atom.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-bonding-and-molecular-structure> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-bonding-and-molecular-structure-hybridization> a kcc:GlossaryTerm ;
  skos:prefLabel '''hybridization''' ;
  skos:definition '''The mixing of atomic orbitals to form new hybrid orbitals of equal energy directed toward bonding partners.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-bonding-and-molecular-structure> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-chemical-bonding-and-molecular-structure-dipole-moment-mu> a kcc:GlossaryTerm ;
  skos:prefLabel '''dipole moment (mu)''' ;
