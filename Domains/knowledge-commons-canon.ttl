<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-einstein-field-equations> a kcc:Formula ;
  rdfs:label '''Einstein field equations''' ;
  math:hasStatement '''G_{mu nu} + Lambda*g_{mu nu} = (8*pi*G/c^4) * T_{mu nu}''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
