  skos:prefLabel '''London dispersion force''' ;
  skos:definition '''A transient induced-dipole/induced-dipole attraction present between all molecules; strength increases with polarizability and molecular mass.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-bonding-and-molecular-structure> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-bonding-and-molecular-structure-bond-order-mo-theory> a kcc:GlossaryTerm ;
  skos:prefLabel '''Bond order (MO theory)''' ;
