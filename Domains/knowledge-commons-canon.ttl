  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-classical-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-classical-mechanics-torque-angular-momentum-relation> a kcc:Formula ;
  rdfs:label '''torque-angular momentum relation''' ;
  math:hasStatement '''tau_net = dL/dt = I * alpha''' ;
