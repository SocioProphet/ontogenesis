<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> skos:scopeNote '''Mendelian inheritance; Non-Mendelian inheritance patterns; Chromosomal inheritance and sex linkage; Linkage, recombination, and genetic mapping; Quantitative genetics; Mutation types; Population genetics; Genomics and human genetics''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-allele> a kcc:GlossaryTerm ;
  skos:prefLabel '''allele''' ;
  skos:definition '''One of two or more alternative forms of a gene at a given locus on a chromosome.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-genotype> a kcc:GlossaryTerm ;
  skos:prefLabel '''genotype''' ;
  skos:definition '''The genetic constitution of an organism at one or more loci.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-phenotype> a kcc:GlossaryTerm ;
  skos:prefLabel '''phenotype''' ;
  skos:definition '''The observable physical or biochemical characteristics of an organism, resulting from genotype and environment.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-dominant> a kcc:GlossaryTerm ;
  skos:prefLabel '''dominant''' ;
  skos:definition '''An allele whose phenotypic effect is expressed in heterozygotes (one copy sufficient); conventionally denoted by uppercase.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-recessive> a kcc:GlossaryTerm ;
  skos:prefLabel '''recessive''' ;
  skos:definition '''An allele whose phenotypic effect is expressed only in homozygotes; masked by the dominant allele in heterozygotes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-homozygous> a kcc:GlossaryTerm ;
  skos:prefLabel '''homozygous''' ;
  skos:definition '''Having two identical alleles at a given locus (AA or aa).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-heterozygous> a kcc:GlossaryTerm ;
  skos:prefLabel '''heterozygous''' ;
  skos:definition '''Having two different alleles at a given locus (Aa).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-test-cross> a kcc:GlossaryTerm ;
  skos:prefLabel '''test cross''' ;
  skos:definition '''Cross between an individual of unknown genotype and a homozygous recessive individual to determine the unknown genotype from offspring ratios.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-codominance> a kcc:GlossaryTerm ;
  skos:prefLabel '''codominance''' ;
  skos:definition '''Both alleles are fully expressed in the heterozygote (e.g., ABO blood type IA and IB alleles).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-incomplete-dominance> a kcc:GlossaryTerm ;
  skos:prefLabel '''incomplete dominance''' ;
  skos:definition '''Heterozygote shows an intermediate phenotype between the two homozygotes (e.g., red × white → pink flowers).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-epistasis> a kcc:GlossaryTerm ;
  skos:prefLabel '''epistasis''' ;
  skos:definition '''Interaction between genes at different loci in which one gene modifies or masks the expression of another.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-genetic-linkage> a kcc:GlossaryTerm ;
  skos:prefLabel '''genetic linkage''' ;
  skos:definition '''Tendency of genes located close together on the same chromosome to be inherited together, deviating from independent assortment.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-genetics-recombination-frequency> a kcc:GlossaryTerm ;
  skos:prefLabel '''recombination frequency''' ;
  skos:definition '''The proportion of recombinant offspring from a cross; used as a measure of genetic distance (1% recombination = 1 centimorgan).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-mendel-s-law-of-segregation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Mendel's Law of Segregation''' ;
  skos:definition '''Each diploid organism carries two alleles for each trait, which separate during gamete formation so each gamete carries only one allele.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-mendel-s-law-of-independent-assortment> a kcc:GlossaryTerm ;
  skos:prefLabel '''Mendel's Law of Independent Assortment''' ;
  skos:definition '''Alleles of different genes assort independently into gametes, provided the genes are on different chromosomes (not linked).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-monohybrid-cross-ratios> a kcc:GlossaryTerm ;
  skos:prefLabel '''Monohybrid cross ratios''' ;
  skos:definition '''Aa × Aa → 1 AA : 2 Aa : 1 aa (3:1 phenotypic ratio for dominant trait).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-dihybrid-cross-ratio> a kcc:GlossaryTerm ;
  skos:prefLabel '''Dihybrid cross ratio''' ;
  skos:definition '''AaBb × AaBb → 9 A_B_ : 3 A_bb : 3 aaB_ : 1 aabb (9:3:3:1 phenotypic ratio).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-hardy-weinberg-equilibrium> a kcc:Formula ;
  rdfs:label '''Hardy-Weinberg equilibrium''' ;
  math:hasStatement '''p² + 2pq + q² = 1; p + q = 1; allele frequencies stay constant in a large, randomly mating, non-evolving population.''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-sex-linked-inheritance> a kcc:GlossaryTerm ;
  skos:prefLabel '''Sex-linked inheritance''' ;
  skos:definition '''X-linked recessive traits expressed in hemizygous males (XY); females are carriers (X^A X^a); never passed father-to-son.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-genetics-chi-square-test-for-genetics> a kcc:Formula ;
  rdfs:label '''Chi-square test for genetics''' ;
  math:hasStatement '''χ² = Σ(observed − expected)² / expected; used to test whether observed ratios deviate from Mendelian expectations.''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-genetics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> a kcc:Topic ;
  skos:prefLabel '''Evolution''' ;
  kcc:level '''intro''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> skos:scopeNote '''Natural selection mechanisms; Types of selection; Speciation; Phylogenetics and systematics; Molecular evolution; Evolutionary forces: drift, mutation, migration; Adaptation and fitness; Macroevolution and the fossil record''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-natural-selection> a kcc:GlossaryTerm ;
  skos:prefLabel '''natural selection''' ;
  skos:definition '''Differential survival and reproduction of individuals with heritable traits that increase fitness in a given environment.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-fitness> a kcc:GlossaryTerm ;
  skos:prefLabel '''fitness''' ;
  skos:definition '''An organism's reproductive success relative to others; the measure of contribution to the gene pool of the next generation.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-adaptation> a kcc:GlossaryTerm ;
  skos:prefLabel '''adaptation''' ;
  skos:definition '''A heritable trait that increases an organism's fitness in its environment, shaped by natural selection over generations.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-genetic-drift> a kcc:GlossaryTerm ;
  skos:prefLabel '''genetic drift''' ;
  skos:definition '''Random changes in allele frequencies in a population, most pronounced in small populations; includes bottleneck and founder effects.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-gene-flow> a kcc:GlossaryTerm ;
  skos:prefLabel '''gene flow''' ;
  skos:definition '''Transfer of alleles between populations through migration of individuals or gametes; tends to homogenize allele frequencies.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-speciation> a kcc:GlossaryTerm ;
  skos:prefLabel '''speciation''' ;
  skos:definition '''The evolutionary process by which populations diverge to form reproductively isolated species; allopatric (geographic) and sympatric are the main modes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-reproductive-isolation> a kcc:GlossaryTerm ;
  skos:prefLabel '''reproductive isolation''' ;
  skos:definition '''Barriers (prezygotic or postzygotic) that prevent interbreeding between populations; the defining criterion of biological species.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-allopatric-speciation> a kcc:GlossaryTerm ;
  skos:prefLabel '''allopatric speciation''' ;
  skos:definition '''Speciation driven by geographic isolation of populations, allowing independent divergence through selection and drift.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-phylogeny> a kcc:GlossaryTerm ;
  skos:prefLabel '''phylogeny''' ;
  skos:definition '''A branching diagram (phylogenetic tree or cladogram) depicting evolutionary relationships among taxa based on shared derived characters.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-homology> a kcc:GlossaryTerm ;
  skos:prefLabel '''homology''' ;
  skos:definition '''Structural or molecular similarity between species due to shared ancestry (e.g., vertebrate forelimbs); distinguished from analogy (convergent evolution).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-molecular-clock> a kcc:GlossaryTerm ;
  skos:prefLabel '''molecular clock''' ;
  skos:definition '''The concept that DNA and protein sequences accumulate mutations at an approximately constant rate, allowing estimation of divergence times.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-evolution-directional-selection> a kcc:GlossaryTerm ;
  skos:prefLabel '''directional selection''' ;
  skos:definition '''Selection that favors one extreme phenotype, shifting the population mean in one direction.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-darwinian-natural-selection-prerequisites> a kcc:GlossaryTerm ;
  skos:prefLabel '''Darwinian natural selection prerequisites''' ;
  skos:definition '''Four conditions required: (1) variation in traits, (2) traits are heritable, (3) differential survival/reproduction, (4) environment is selective.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-types-of-natural-selection> a kcc:GlossaryTerm ;
  skos:prefLabel '''Types of natural selection''' ;
  skos:definition '''Directional (favors one extreme) → shifts mean; Stabilizing (favors intermediate) → reduces variance; Disruptive (favors both extremes) → bimodal distribution.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-hardy-weinberg-conditions-evolution-null-model> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hardy-Weinberg conditions (evolution null model)''' ;
  skos:definition '''No evolution if: large population, random mating, no mutation, no migration, no selection. Deviations signal evolutionary forces.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-allopatric-speciation-process> a kcc:GlossaryTerm ;
  skos:prefLabel '''Allopatric speciation process''' ;
  skos:definition '''Geographic barrier → isolated populations → independent divergence via selection/drift → reproductive isolation → new species if secondary contact fails to produce fertile hybrids.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-phylogenetic-parsimony> a kcc:GlossaryTerm ;
  skos:prefLabel '''Phylogenetic parsimony''' ;
  skos:definition '''The preferred phylogeny is the one requiring the fewest evolutionary changes (character state transitions) to explain observed data.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-evolution-sexual-selection> a kcc:GlossaryTerm ;
  skos:prefLabel '''Sexual selection''' ;
  skos:definition '''A form of natural selection where traits increase mating success rather than survival; intrasexual (competition) and intersexual (mate choice) modes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-evolution> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> a kcc:Topic ;
  skos:prefLabel '''Ecology''' ;
  kcc:level '''intro''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> skos:scopeNote '''Population ecology and growth models; Species interactions; Community ecology; Ecosystem energy flow and productivity; Nutrient cycling (biogeochemical cycles); Biomes and aquatic ecosystems; Succession; Conservation biology and biodiversity''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-population> a kcc:GlossaryTerm ;
  skos:prefLabel '''population''' ;
  skos:definition '''A group of individuals of the same species living in the same area at the same time.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-carrying-capacity-k> a kcc:GlossaryTerm ;
  skos:prefLabel '''carrying capacity (K)''' ;
  skos:definition '''The maximum population size that an environment can sustain indefinitely, given available resources.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-exponential-growth> a kcc:GlossaryTerm ;
  skos:prefLabel '''exponential growth''' ;
  skos:definition '''Unrestricted population growth at a constant per-capita rate (r), occurring when resources are unlimited (J-shaped curve).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-logistic-growth> a kcc:GlossaryTerm ;
  skos:prefLabel '''logistic growth''' ;
  skos:definition '''Population growth that slows as density increases due to resource limitation; follows an S-shaped curve, approaching carrying capacity K.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-keystone-species> a kcc:GlossaryTerm ;
  skos:prefLabel '''keystone species''' ;
  skos:definition '''A species that has a disproportionately large effect on community structure relative to its abundance (e.g., sea otters controlling urchin populations).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-niche> a kcc:GlossaryTerm ;
  skos:prefLabel '''niche''' ;
  skos:definition '''The ecological role and hypervolume of conditions (food, habitat, timing) used by a species; fundamental niche vs. realized niche.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-competitive-exclusion-principle> a kcc:GlossaryTerm ;
  skos:prefLabel '''competitive exclusion principle''' ;
  skos:definition '''Two species competing for identical resources cannot coexist indefinitely; one will outcompete and exclude the other.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-trophic-level> a kcc:GlossaryTerm ;
  skos:prefLabel '''trophic level''' ;
  skos:definition '''Position in a food chain defined by the number of energy-transfer steps from primary producers: producers, primary consumers, secondary consumers, etc.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-biomass-pyramid> a kcc:GlossaryTerm ;
  skos:prefLabel '''biomass pyramid''' ;
  skos:definition '''Diagram showing the total dry mass of organisms at each trophic level; typically decreases at higher levels (~10% energy transfer efficiency).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-symbiosis> a kcc:GlossaryTerm ;
  skos:prefLabel '''symbiosis''' ;
  skos:definition '''A close, persistent ecological relationship between two species; types include mutualism, commensalism, and parasitism.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-succession> a kcc:GlossaryTerm ;
  skos:prefLabel '''succession''' ;
  skos:definition '''Directional change in community composition over time; primary succession starts on bare substrate; secondary succession follows disturbance of existing community.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-ecology-net-primary-productivity-npp> a kcc:GlossaryTerm ;
  skos:prefLabel '''net primary productivity (NPP)''' ;
  skos:definition '''The rate at which producers fix energy minus their own respiration; the energy available to primary consumers.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-exponential-population-growth> a kcc:Formula ;
  rdfs:label '''Exponential population growth''' ;
  math:hasStatement '''dN/dt = rN; N(t) = N₀·e^(rt)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-logistic-population-growth> a kcc:Formula ;
  rdfs:label '''Logistic population growth''' ;
  math:hasStatement '''dN/dt = rN·(K − N)/K; growth rate is maximal at N = K/2 and declines to zero as N approaches K.''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-10-energy-rule> a kcc:GlossaryTerm ;
  skos:prefLabel '''10% energy rule''' ;
  skos:definition '''Approximately 10% of energy is transferred from one trophic level to the next; the rest is lost as heat or used in respiration.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-lotka-volterra-predator-prey-dynamics> a kcc:GlossaryTerm ;
  skos:prefLabel '''Lotka-Volterra predator-prey dynamics''' ;
  skos:definition '''Predator and prey populations cycle out of phase: prey increase → predator increase → prey decrease → predator decrease → prey rebound.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-nitrogen-cycle-key-processes> a kcc:GlossaryTerm ;
  skos:prefLabel '''Nitrogen cycle key processes''' ;
  skos:definition '''Nitrogen fixation (N₂ → NH₃ by bacteria) → nitrification (NH₃ → NO₂⁻ → NO₃⁻) → assimilation → ammonification → denitrification (NO₃⁻ → N₂).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-ecology-community-diversity-indices> a kcc:GlossaryTerm ;
  skos:prefLabel '''Community diversity indices''' ;
  skos:definition '''Species richness (number of species); species evenness (relative abundance); Shannon diversity index H' = −Σ(pᵢ·ln pᵢ).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-ecology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> a kcc:Topic ;
  skos:prefLabel '''Physiology: Nervous and Endocrine Systems''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> skos:scopeNote '''Neuron structure and action potentials; Synaptic transmission; Central and peripheral nervous system organization; Sensory systems; Endocrine glands and hormones; Hormone signaling mechanisms; Feedback loops in homeostasis; Neuroendocrine integration''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-resting-membrane-potential> a kcc:GlossaryTerm ;
  skos:prefLabel '''resting membrane potential''' ;
  skos:definition '''The electrical potential across the plasma membrane of a resting neuron, typically −70 mV, maintained by K⁺ leak channels and the Na⁺/K⁺ ATPase.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-action-potential> a kcc:GlossaryTerm ;
  skos:prefLabel '''action potential''' ;
  skos:definition '''A rapid, all-or-none depolarization and repolarization of the neuronal membrane, propagating along the axon without decrement.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-depolarization> a kcc:GlossaryTerm ;
  skos:prefLabel '''depolarization''' ;
  skos:definition '''Change in membrane potential toward less negative values; occurs when Na⁺ rushes in through voltage-gated Na⁺ channels at threshold (~−55 mV).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-synapse> a kcc:GlossaryTerm ;
  skos:prefLabel '''synapse''' ;
  skos:definition '''A junction between two neurons (or neuron and effector) where electrical or chemical signals are transmitted.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-neurotransmitter> a kcc:GlossaryTerm ;
  skos:prefLabel '''neurotransmitter''' ;
  skos:definition '''Chemical signal released from a presynaptic terminal that binds to postsynaptic receptors to transmit the nerve signal.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-hormone> a kcc:GlossaryTerm ;
  skos:prefLabel '''hormone''' ;
  skos:definition '''A chemical messenger secreted by an endocrine gland into the bloodstream that regulates physiology and behavior of distant target cells.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-negative-feedback> a kcc:GlossaryTerm ;
  skos:prefLabel '''negative feedback''' ;
  skos:definition '''Regulatory mechanism in which a change in a variable triggers a response that opposes and reverses that change, maintaining homeostasis.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-epsp-ipsp> a kcc:GlossaryTerm ;
  skos:prefLabel '''EPSP/IPSP''' ;
  skos:definition '''Excitatory/inhibitory postsynaptic potential; small depolarizations or hyperpolarizations that summate (temporal and spatial summation) to determine if threshold is reached.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-myelin-sheath> a kcc:GlossaryTerm ;
  skos:prefLabel '''myelin sheath''' ;
  skos:definition '''Lipid-rich insulation formed by oligodendrocytes (CNS) or Schwann cells (PNS) that speeds action potential propagation by saltatory conduction.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-nernst-potential> a kcc:GlossaryTerm ;
  skos:prefLabel '''Nernst potential''' ;
  skos:definition '''The equilibrium membrane potential for a single ion species, at which the electrical gradient exactly opposes the chemical gradient.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-hypothalamic-pituitary-axis> a kcc:GlossaryTerm ;
  skos:prefLabel '''hypothalamic-pituitary axis''' ;
  skos:definition '''Central neuroendocrine control hub: hypothalamic releasing/inhibiting hormones regulate anterior pituitary hormone secretion, which controls peripheral endocrine glands.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-nervous-and-endocrine-systems-second-messenger> a kcc:GlossaryTerm ;
  skos:prefLabel '''second messenger''' ;
  skos:definition '''Intracellular signaling molecule (cAMP, IP3, DAG, Ca²⁺) generated in response to hormone-receptor binding, amplifying and transducing the signal.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-nervous-and-endocrine-systems-nernst-equation> a kcc:Formula ;
  rdfs:label '''Nernst equation''' ;
  math:hasStatement '''E_ion = (RT/zF) · ln([ion]_out / [ion]_in) ≈ (61.5/z) · log₁₀([ion]_out / [ion]_in) mV at 37°C''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-nervous-and-endocrine-systems-action-potential-sequence> a kcc:GlossaryTerm ;
  skos:prefLabel '''Action potential sequence''' ;
  skos:definition '''Resting (−70 mV) → threshold stimulus → voltage-gated Na⁺ channels open → rapid depolarization (+30 mV) → inactivation of Na⁺ channels → K⁺ channels open → repolarization → hyperpolarization → refractory period → reset.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-nervous-and-endocrine-systems-chemical-synapse-transmission> a kcc:GlossaryTerm ;
  skos:prefLabel '''Chemical synapse transmission''' ;
  skos:definition '''Action potential arrives → Ca²⁺ influx at presynaptic terminal → vesicle fusion → neurotransmitter released into cleft → binds postsynaptic receptors → EPSP or IPSP → reuptake/degradation.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-nervous-and-endocrine-systems-hypothalamic-pituitary-thyroid-axis> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hypothalamic-pituitary-thyroid axis''' ;
  skos:definition '''Low T3/T4 → hypothalamus releases TRH → pituitary releases TSH → thyroid releases T3/T4 → negative feedback to hypothalamus and pituitary.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-nervous-and-endocrine-systems-hormone-receptor-mechanisms> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hormone receptor mechanisms''' ;
  skos:definition '''Peptide hormones: bind surface receptors → second messengers (fast). Steroid hormones: lipid-soluble, cross membrane → intracellular receptors → direct gene regulation (slow, sustained).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-nervous-and-endocrine-systems> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> a kcc:Topic ;
  skos:prefLabel '''Physiology: Cardiovascular, Respiratory, and Renal Systems''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> skos:scopeNote '''Heart anatomy and cardiac cycle; Blood pressure and vascular resistance; Blood composition and hemoglobin; Gas exchange and oxygen transport; Ventilation mechanics; Kidney structure and nephron function; Urine formation: filtration, reabsorption, secretion; Fluid and electrolyte homeostasis''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-cardiac-output> a kcc:GlossaryTerm ;
  skos:prefLabel '''cardiac output''' ;
  skos:definition '''Volume of blood pumped by the heart per minute: CO = stroke volume × heart rate; normal ~5 L/min at rest.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-stroke-volume> a kcc:GlossaryTerm ;
  skos:prefLabel '''stroke volume''' ;
  skos:definition '''Volume of blood ejected by the left ventricle per beat; influenced by preload, contractility, and afterload.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-hemoglobin> a kcc:GlossaryTerm ;
  skos:prefLabel '''hemoglobin''' ;
  skos:definition '''The tetrameric oxygen-transport protein in red blood cells; each subunit carries one heme group that binds one O₂ molecule cooperatively.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-oxyhemoglobin-dissociation-curve> a kcc:GlossaryTerm ;
  skos:prefLabel '''oxyhemoglobin dissociation curve''' ;
  skos:definition '''Sigmoidal curve describing hemoglobin O₂ saturation as a function of pO₂; rightward shift (Bohr effect) with ↑CO₂, ↑H⁺, ↑temperature, ↑2,3-BPG.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-alveolus> a kcc:GlossaryTerm ;
  skos:prefLabel '''alveolus''' ;
  skos:definition '''Tiny air sac in the lung across whose thin wall (type I pneumocytes) gas exchange occurs between air and pulmonary capillaries.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-glomerular-filtration-rate-gfr> a kcc:GlossaryTerm ;
  skos:prefLabel '''glomerular filtration rate (GFR)''' ;
  skos:definition '''Volume of plasma filtered by the kidneys per minute (~125 mL/min); a key indicator of kidney function.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-nephron> a kcc:GlossaryTerm ;
  skos:prefLabel '''nephron''' ;
  skos:definition '''The functional unit of the kidney; consists of the glomerulus, Bowman's capsule, proximal tubule, loop of Henle, distal tubule, and collecting duct.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-reabsorption> a kcc:GlossaryTerm ;
  skos:prefLabel '''reabsorption''' ;
  skos:definition '''Recovery of filtered substances (glucose, amino acids, Na⁺, water) from the tubular lumen back into peritubular capillaries.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-frank-starling-mechanism> a kcc:GlossaryTerm ;
  skos:prefLabel '''Frank-Starling mechanism''' ;
  skos:definition '''The intrinsic ability of the heart to increase stroke volume in response to increased venous return (preload), due to greater sarcomere stretch.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-bohr-effect> a kcc:GlossaryTerm ;
  skos:prefLabel '''Bohr effect''' ;
  skos:definition '''Reduced hemoglobin-O₂ affinity at lower pH and higher CO₂, facilitating O₂ unloading in metabolically active tissues.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-renin-angiotensin-aldosterone-system-raas> a kcc:GlossaryTerm ;
  skos:prefLabel '''renin-angiotensin-aldosterone system (RAAS)''' ;
  skos:definition '''Hormonal cascade activated by low blood pressure/Na⁺: renin (kidney) → angiotensin I → ACE → angiotensin II → aldosterone release → Na⁺ and water retention → BP increase.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-physiology-cardiovascular-respiratory-and-renal-systems-antidiuretic-hormone-adh-vasopressin> a kcc:GlossaryTerm ;
  skos:prefLabel '''antidiuretic hormone (ADH/vasopressin)''' ;
  skos:definition '''Posterior pituitary peptide that increases water reabsorption in the collecting duct by inserting aquaporin-2 channels, concentrating urine.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-cardiovascular-respiratory-and-renal-systems-cardiac-output-equation> a kcc:Formula ;
  rdfs:label '''Cardiac output equation''' ;
  math:hasStatement '''CO = SV × HR; MAP ≈ CO × TPR (total peripheral resistance)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-cardiovascular-respiratory-and-renal-systems-oxygen-transport> a kcc:GlossaryTerm ;
  skos:prefLabel '''Oxygen transport''' ;
  skos:definition '''O₂ bound to hemoglobin (97%) and dissolved in plasma (3%); cooperative binding (Hill coefficient ~2.8); O₂ content = (Hb × 1.34 × SaO₂) + (0.003 × pO₂).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-cardiovascular-respiratory-and-renal-systems-urine-formation-in-nephron> a kcc:GlossaryTerm ;
  skos:prefLabel '''Urine formation in nephron''' ;
  skos:definition '''Glomerular filtration (pressure-driven, ~125 mL/min) → tubular reabsorption (Na⁺, glucose, water) → secretion (H⁺, K⁺, drugs) → final urine ~1.5 L/day.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-cardiovascular-respiratory-and-renal-systems-henderson-hasselbalch-equation-blood-ph> a kcc:Formula ;
  rdfs:label '''Henderson-Hasselbalch equation (blood pH)''' ;
  math:hasStatement '''pH = pKa + log([HCO₃⁻] / [H₂CO₃]); normal arterial pH 7.4, [HCO₃⁻] 24 mEq/L, PCO₂ 40 mmHg.''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-physiology-cardiovascular-respiratory-and-renal-systems-ventilation-perfusion-matching> a kcc:GlossaryTerm ;
  skos:prefLabel '''Ventilation-perfusion matching''' ;
  skos:definition '''Efficient gas exchange requires matched V/Q ratios; pulmonary vessels constrict in hypoxic regions (HPV) to divert blood to ventilated alveoli.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-physiology-cardiovascular-respiratory-and-renal-systems> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> a kcc:Topic ;
  skos:prefLabel '''Microbiology''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
