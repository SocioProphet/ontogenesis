<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-ladder-operator-algebra> a kcc:Formula ;
  rdfs:label '''ladder operator algebra''' ;
  math:hasStatement '''[â, â†] = 1;  â†|n> = sqrt(n+1)|n+1>;  â|n> = sqrt(n)|n-1>''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
