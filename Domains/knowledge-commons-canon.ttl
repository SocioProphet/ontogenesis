<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-fourier-transform-pair> a kcc:GlossaryTerm ;
  skos:prefLabel '''Fourier transform pair''' ;
  skos:definition '''f̃(k) = ∫_{-inf}^{inf} f(x)*exp(-i*k*x) dx;  f(x) = (1/(2*pi))*∫ f̃(k)*exp(i*k*x) dk''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
  kcc:canonType '''definition''' ;
