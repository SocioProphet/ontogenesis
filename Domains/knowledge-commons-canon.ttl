<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-astrophysics-and-cosmology-friedmann-equation> a kcc:Formula ;
  rdfs:label '''Friedmann equation''' ;
  math:hasStatement '''H^2 = (8*pi*G/3)*rho - k*c^2/a^2 + Lambda*c^2/3''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-astrophysics-and-cosmology> ;
