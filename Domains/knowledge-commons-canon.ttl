<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-translational-partition-function-3d> a kcc:Formula ;
  rdfs:label '''Translational partition function (3D)''' ;
  math:hasStatement '''q_trans = (2*pi*m*k_B*T / h^2)^(3/2) * V  (de Broglie thermal volume)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
