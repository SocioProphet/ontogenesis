<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-electrochemistry-cell-potential-standard> a kcc:Formula ;
  rdfs:label '''Cell potential (standard)''' ;
  math:hasStatement '''E^o_cell = E^o_cathode - E^o_anode''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-electrochemistry> ;
