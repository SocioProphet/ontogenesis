<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-biochemistry-fundamentals-vmax> a kcc:GlossaryTerm ;
  skos:prefLabel '''Vmax''' ;
  skos:definition '''The maximum velocity of an enzymatic reaction at saturating substrate concentration; equals k_cat times total enzyme concentration.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-michaelis-menten-equation> a kcc:Formula ;
  rdfs:label '''Michaelis-Menten equation''' ;
  math:hasStatement '''v = V_max * [S] / (K_M + [S])''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-enzyme-turnover-number> a kcc:GlossaryTerm ;
  skos:prefLabel '''Enzyme turnover number''' ;
  skos:definition '''k_cat = V_max / [E]_total''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-catalytic-efficiency> a kcc:GlossaryTerm ;
  skos:prefLabel '''Catalytic efficiency''' ;
  skos:definition '''k_cat / K_M  (second-order rate constant for E + S -> product; diffusion limit ~ 10^8 to 10^9 M^-1 s^-1)''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-competitive-inhibition-apparent-k-m> a kcc:Formula ;
  rdfs:label '''Competitive inhibition (apparent K_M)''' ;
  math:hasStatement '''K_M_app = K_M * (1 + [I]/K_I)  V_max unchanged''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-uncompetitive-inhibition> a kcc:Formula ;
  rdfs:label '''Uncompetitive inhibition''' ;
  math:hasStatement '''K_M_app = K_M / (1 + [I]/K_I')  V_max_app = V_max / (1 + [I]/K_I')''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-biochemistry-fundamentals-atp-hydrolysis-free-energy-standard-biological> a kcc:GlossaryTerm ;
  skos:prefLabel '''ATP hydrolysis free energy (standard biological)''' ;
  skos:definition '''delta_G^o' = -30.5 kJ/mol  (pH 7, 25 degrees C, 1 mM Mg2+)''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-biochemistry-fundamentals> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
