  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
