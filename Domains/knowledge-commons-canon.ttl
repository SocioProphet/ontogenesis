  skos:prefLabel '''multiplicity of a root''' ;
  skos:definition '''The number of times a root r appears as a factor; r has multiplicity k if (x - r)^k | p(x) but (x - r)^(k+1) does not.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-algebra-and-polynomial-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
