<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-canonical-partition-function> a kcc:Formula ;
  rdfs:label '''canonical partition function''' ;
  math:hasStatement '''Z = sum_i exp(-E_i / (k_B*T))''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
