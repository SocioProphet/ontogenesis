  skos:prefLabel '''Markovnikov's rule''' ;
  skos:definition '''In electrophilic addition to an unsymmetrical alkene, the electrophile (H+) adds to the carbon with more hydrogen atoms.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-organic-reactions-and-mechanisms> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
