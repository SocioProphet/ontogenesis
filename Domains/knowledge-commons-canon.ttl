<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-equipartition-theorem> a kcc:Formula ;
  rdfs:label '''equipartition theorem''' ;
  math:hasStatement '''<(1/2)*a*q^2> = (1/2)*k_B*T for each quadratic DoF''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
