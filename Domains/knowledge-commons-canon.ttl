<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-nuclear-and-atomic-physics-zeeman-effect> a kcc:GlossaryTerm ;
  skos:prefLabel '''Zeeman effect''' ;
  skos:definition '''Splitting of atomic spectral lines in an external magnetic field; normal Zeeman: triplet (for S=0 states); anomalous Zeeman involves spin.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-nuclear-and-atomic-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
