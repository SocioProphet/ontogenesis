<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-angular-momentum-commutators> a kcc:Formula ;
  rdfs:label '''angular momentum commutators''' ;
  math:hasStatement '''[L_i, L_j] = iℏ * ε_ijk * L_k;  [L^2, L_i] = 0''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
