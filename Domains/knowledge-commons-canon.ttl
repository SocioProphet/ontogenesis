  rdfs:label '''Maxwell-Boltzmann speed distribution''' ;
  math:hasStatement '''f(v) = 4*pi*n*(m/(2*pi*k_B*T))^(3/2) * v^2 * exp(-m*v^2/(2*k_B*T))''' ;
