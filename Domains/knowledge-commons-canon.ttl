<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-coordination-chemistry-and-inorganic-chemistry-crystal-field-d-orbital-splitting-octahedral> a kcc:GlossaryTerm ;
  skos:prefLabel '''Crystal field d-orbital splitting (octahedral)''' ;
  skos:definition '''e_g set (d_z2, d_x2-y2) raised by +3/5 Delta_oct; t_2g set (d_xy, d_xz, d_yz) lowered by -2/5 Delta_oct''' ;
