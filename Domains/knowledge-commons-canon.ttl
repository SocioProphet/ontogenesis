  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-special-relativity> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-special-relativity-rest-energy> a kcc:Formula ;
  rdfs:label '''rest energy''' ;
  math:hasStatement '''E_0 = m*c^2''' ;
