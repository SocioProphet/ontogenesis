<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-precalculus-and-functions-de-moivre-s-theorem> a math:Equation ;
  rdfs:label '''De Moivre's theorem''' ;
  math:hasStatement '''(cos θ + i sin θ)^n = cos(nθ) + i sin(nθ)''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
