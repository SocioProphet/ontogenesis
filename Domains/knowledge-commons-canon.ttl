<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-angular-momentum-eigenvalues> a kcc:Formula ;
  rdfs:label '''angular momentum eigenvalues''' ;
  math:hasStatement '''L^2|l,m> = ℏ^2*l(l+1)|l,m>;  L_z|l,m> = ℏ*m|l,m>;  l=0,1,2,...;  m=-l,...,+l''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-hydrogen-atom-energy-levels> a kcc:Formula ;
  rdfs:label '''hydrogen atom energy levels''' ;
  math:hasStatement '''E_n = -13.6 eV / n^2 = -m_e*e^4 / (2ℏ^2*(4πε_0)^2*n^2)''' ;
