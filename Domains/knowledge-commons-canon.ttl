<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-algebra-and-polynomial-theory-fundamental-theorem-of-algebra> a math:Equation ;
  rdfs:label '''Fundamental theorem of algebra''' ;
  math:hasStatement '''Every non-constant polynomial with complex coefficients has at least one complex root; equivalently, a degree-n polynomial has exactly n roots in ℂ (counted with multiplicity).''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-algebra-and-polynomial-theory> ;
