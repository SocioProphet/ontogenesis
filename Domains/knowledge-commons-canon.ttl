<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-geodesic-equation> a kcc:Formula ;
  rdfs:label '''geodesic equation''' ;
  math:hasStatement '''d^2x^lambda/dtau^2 + Gamma^lambda_{mu nu} * dx^mu/dtau * dx^nu/dtau = 0''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
