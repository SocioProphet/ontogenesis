  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> skos:scopeNote '''DNA structure and replication; Transcription and RNA processing; Translation and the genetic code; Gene regulation in prokaryotes; Gene regulation in eukaryotes; Mutations and DNA repair; Recombinant DNA and biotechnology; Epigenetics''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-dna-replication> a kcc:GlossaryTerm ;
  skos:prefLabel '''DNA replication''' ;
  skos:definition '''Semiconservative copying of DNA by DNA polymerase III (prokaryotes) / Pol δ, ε (eukaryotes), always 5'→3', requiring an RNA primer.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-transcription> a kcc:GlossaryTerm ;
  skos:prefLabel '''transcription''' ;
  skos:definition '''Synthesis of an RNA molecule complementary to the DNA template strand, catalyzed by RNA polymerase.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-translation> a kcc:GlossaryTerm ;
  skos:prefLabel '''translation''' ;
  skos:definition '''Ribosomal synthesis of a polypeptide chain from an mRNA template, reading codons 5'→3' and assembling amino acids N→C.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-codon> a kcc:GlossaryTerm ;
  skos:prefLabel '''codon''' ;
  skos:definition '''A three-nucleotide sequence in mRNA that specifies one amino acid or a stop signal; the genetic code is read in non-overlapping triplets.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-promoter> a kcc:GlossaryTerm ;
  skos:prefLabel '''promoter''' ;
  skos:definition '''DNA sequence upstream of a gene to which RNA polymerase and transcription factors bind to initiate transcription.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-operon> a kcc:GlossaryTerm ;
  skos:prefLabel '''operon''' ;
  skos:definition '''A unit of prokaryotic gene regulation consisting of a promoter, operator, and co-transcribed structural genes (e.g., the lac operon).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-mrna-splicing> a kcc:GlossaryTerm ;
  skos:prefLabel '''mRNA splicing''' ;
  skos:definition '''Post-transcriptional removal of introns and ligation of exons by the spliceosome to produce mature mRNA in eukaryotes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-start-codon> a kcc:GlossaryTerm ;
  skos:prefLabel '''start codon''' ;
  skos:definition '''AUG; codes for methionine (Met) and defines the start of the open reading frame in translation.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-stop-codon> a kcc:GlossaryTerm ;
  skos:prefLabel '''stop codon''' ;
  skos:definition '''UAA, UAG, or UGA; codons that signal termination of translation and release of the polypeptide.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-dna-polymerase> a kcc:GlossaryTerm ;
  skos:prefLabel '''DNA polymerase''' ;
  skos:definition '''Enzyme that synthesizes new DNA strands in the 5'→3' direction using a template; requires a primer and has 3'→5' proofreading exonuclease activity.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-restriction-enzyme> a kcc:GlossaryTerm ;
  skos:prefLabel '''restriction enzyme''' ;
  skos:definition '''Endonuclease that cleaves double-stranded DNA at specific recognition sequences; used as a tool in recombinant DNA technology.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-pcr> a kcc:GlossaryTerm ;
  skos:prefLabel '''PCR''' ;
  skos:definition '''Polymerase chain reaction; in vitro method to exponentially amplify a specific DNA region using primers, Taq polymerase, and thermal cycling.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-molecular-biology-epigenetics> a kcc:GlossaryTerm ;
  skos:prefLabel '''epigenetics''' ;
  skos:definition '''Heritable changes in gene expression that do not involve changes in DNA sequence, mediated by histone modification, DNA methylation, and chromatin remodeling.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-central-dogma> a kcc:GlossaryTerm ;
  skos:prefLabel '''Central dogma''' ;
  skos:definition '''DNA → (transcription) → RNA → (translation) → Protein; information flows from nucleic acid sequence to amino acid sequence.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-semiconservative-replication> a kcc:GlossaryTerm ;
  skos:prefLabel '''Semiconservative replication''' ;
  skos:definition '''Each new DNA double helix contains one original (template) strand and one newly synthesized strand; demonstrated by Meselson-Stahl experiment.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-lac-operon-regulation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Lac operon regulation''' ;
  skos:definition '''In absence of lactose: repressor binds operator, blocking transcription. In presence of lactose: allolactose binds repressor, releases operator, allows transcription. cAMP-CAP provides positive regulation when glucose is absent.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-eukaryotic-transcription-regulation> a kcc:GlossaryTerm ;
  skos:prefLabel '''Eukaryotic transcription regulation''' ;
  skos:definition '''Transcription factors bind enhancers/silencers; mediator complex bridges to RNA Pol II at the promoter; chromatin accessibility (histone acetylation) gates access.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-mrna-processing-in-eukaryotes> a kcc:GlossaryTerm ;
  skos:prefLabel '''mRNA processing in eukaryotes''' ;
  skos:definition '''5' 7-methylguanosine cap addition → splicing of introns by spliceosome → 3' poly-A tail addition; produces mature mRNA exported to cytoplasm.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-genetic-code-properties> a kcc:GlossaryTerm ;
  skos:prefLabel '''Genetic code properties''' ;
  skos:definition '''Triplet codons (64 total: 61 sense + 3 stop); degenerate (multiple codons per amino acid); universal across nearly all life; non-overlapping and comma-free.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-molecular-biology-dna-repair-mechanisms> a kcc:GlossaryTerm ;
  skos:prefLabel '''DNA repair mechanisms''' ;
  skos:definition '''Mismatch repair (corrects replication errors); nucleotide excision repair (bulky lesions, UV damage); base excision repair (modified bases); homologous recombination / NHEJ (double-strand breaks).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-molecular-biology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
