<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-plasma-physics-and-fluid-dynamics-plasma-frequency> a kcc:GlossaryTerm ;
  skos:prefLabel '''plasma frequency''' ;
  skos:definition '''ω_p = sqrt(n_e e^2 / (ε_0 m_e)); the natural oscillation frequency of electron density fluctuations; waves with ω < ω_p cannot propagate in the plasma.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-plasma-physics-and-fluid-dynamics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-plasma-physics-and-fluid-dynamics-magnetic-pressure> a kcc:GlossaryTerm ;
  skos:prefLabel '''magnetic pressure''' ;
  skos:definition '''P_B = B^2/(2μ_0); the isotropic pressure exerted by a magnetic field; the ratio of plasma to magnetic pressure is β = P/(B^2/2μ_0).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-plasma-physics-and-fluid-dynamics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
