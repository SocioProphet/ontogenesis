<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-mathematical-methods-in-physics-gauss-s-theorem-divergence-theorem> a kcc:Formula ;
  rdfs:label '''Gauss's theorem (divergence theorem)''' ;
  math:hasStatement '''∫∫_S F · dA = ∫∫∫_V (∇·F) dV''' ;
  kcc:canonType '''theorem''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
