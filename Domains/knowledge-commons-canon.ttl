<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-nuclear-and-atomic-physics-semi-empirical-mass-formula-semf> a kcc:Formula ;
  rdfs:label '''semi-empirical mass formula (SEMF)''' ;
  math:hasStatement '''B = a_V*A - a_S*A^(2/3) - a_C*Z^2/A^(1/3) - a_A*(A-2Z)^2/A ± delta''' ;
