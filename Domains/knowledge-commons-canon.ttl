<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-einstein-tensor> a kcc:GlossaryTerm ;
  skos:prefLabel '''Einstein tensor''' ;
  skos:definition '''G_{mu nu} = R_{mu nu} - (1/2)*g_{mu nu}*R''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
