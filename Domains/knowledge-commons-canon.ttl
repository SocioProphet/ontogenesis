<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-analytical-chemistry-and-solution-equilibria-van-deemter-equation> a kcc:Formula ;
  rdfs:label '''van Deemter equation''' ;
  math:hasStatement '''H = A + B/u + C*u''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-analytical-chemistry-and-solution-equilibria> ;
