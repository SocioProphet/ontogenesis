<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-nuclear-and-atomic-physics-selection-rules-electric-dipole> a kcc:GlossaryTerm ;
  skos:prefLabel '''selection rules (electric dipole)''' ;
  skos:definition '''Transitions are allowed only if Δl = ±1, Δm_l = 0, ±1, Δm_s = 0; forbidden otherwise (no photon angular momentum budget).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-nuclear-and-atomic-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
