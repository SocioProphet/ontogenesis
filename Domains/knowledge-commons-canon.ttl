<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-rotational-partition-function-linear-molecule-high-t> a kcc:Formula ;
  rdfs:label '''Rotational partition function (linear molecule, high T)''' ;
  math:hasStatement '''q_rot = T / (sigma * Theta_rot)  where Theta_rot = h_bar^2 / (2*I*k_B)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-vibrational-partition-function-harmonic> a kcc:Formula ;
  rdfs:label '''Vibrational partition function (harmonic)''' ;
  math:hasStatement '''q_vib = exp(-Theta_vib/(2T)) / (1 - exp(-Theta_vib/T))  where Theta_vib = h*nu/k_B''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-boltzmann-entropy-microcanonical> a kcc:Formula ;
  rdfs:label '''Boltzmann entropy (microcanonical)''' ;
  math:hasStatement '''S = k_B * ln(Omega)''' ;
