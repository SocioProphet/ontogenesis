<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-astrophysics-and-cosmology-density-parameter> a kcc:GlossaryTerm ;
  skos:prefLabel '''density parameter''' ;
  skos:definition '''Omega = rho/rho_crit;  rho_crit = 3*H^2/(8*pi*G);  Omega_total=1 (flat universe)''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-astrophysics-and-cosmology> ;
  kcc:canonType '''definition''' ;
