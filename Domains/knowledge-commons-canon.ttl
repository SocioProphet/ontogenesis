<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-speed-of-light> a kcc:Formula ;
  rdfs:label '''speed of light''' ;
  math:hasStatement '''c = 1/sqrt(epsilon_0 * mu_0) = 2.998e8 m/s''' ;
