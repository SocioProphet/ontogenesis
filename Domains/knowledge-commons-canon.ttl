<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-thermodynamics-classical-internal-energy-ideal-monatomic-gas> a kcc:Formula ;
  rdfs:label '''internal energy (ideal monatomic gas)''' ;
  math:hasStatement '''U = (3/2)*n*R*T''' ;
  kcc:canonType '''equation''' ;
