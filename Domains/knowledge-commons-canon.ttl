<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-fermi-dirac-distribution> a kcc:Formula ;
  rdfs:label '''Fermi-Dirac distribution''' ;
  math:hasStatement '''f_FD(epsilon) = 1 / (exp(beta*(epsilon - mu)) + 1)''' ;
