<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-sackur-tetrode-equation-ideal-gas-entropy> a kcc:Formula ;
  rdfs:label '''Sackur-Tetrode equation (ideal gas entropy)''' ;
  math:hasStatement '''S/N*k_B = ln(V/N * (4*pi*m*U/(3*N*h^2))^(3/2)) + 5/2''' ;
  kcc:canonType '''equation''' ;
