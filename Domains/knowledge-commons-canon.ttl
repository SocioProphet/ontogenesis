<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-electrochemistry-faraday-s-constant-f> a kcc:GlossaryTerm ;
  skos:prefLabel '''Faraday's constant (F)''' ;
