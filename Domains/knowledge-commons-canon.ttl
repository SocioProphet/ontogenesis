<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-arithmetic-sequence> a kcc:GlossaryTerm ;
  skos:prefLabel '''arithmetic sequence''' ;
