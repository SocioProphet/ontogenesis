<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-astrophysics-and-cosmology-acceleration-equation> a kcc:Formula ;
  rdfs:label '''acceleration equation''' ;
  math:hasStatement '''a_ddot/a = -(4*pi*G/3)*(rho + 3*P/c^2) + Lambda*c^2/3''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-astrophysics-and-cosmology> ;
