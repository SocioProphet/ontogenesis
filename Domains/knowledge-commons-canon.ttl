  skos:prefLabel '''Hund's rule''' ;
  skos:definition '''Electrons occupy orbitals of equal energy singly with parallel spins before pairing.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-atomic-structure-and-quantum-chemistry> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-atomic-structure-and-quantum-chemistry-pauli-exclusion-principle> a kcc:GlossaryTerm ;
  skos:prefLabel '''Pauli exclusion principle''' ;
  skos:definition '''No two electrons in an atom can have the same four quantum numbers; each orbital holds at most two electrons with opposite spin.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-atomic-structure-and-quantum-chemistry> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-atomic-structure-and-quantum-chemistry-effective-nuclear-charge-z-eff> a kcc:GlossaryTerm ;
  skos:prefLabel '''effective nuclear charge (Z_eff)''' ;
