<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-faraday-s-law-integral> a kcc:Formula ;
  rdfs:label '''Faraday's law (integral)''' ;
  math:hasStatement '''∮ E · dl = -d/dt ∫∫ B · dA''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-electromagnetism-amp-re-maxwell-law-integral> a kcc:Formula ;
  rdfs:label '''Ampère-Maxwell law (integral)''' ;
  math:hasStatement '''∮ B · dl = mu_0 * (I_enc + epsilon_0 * d/dt ∫∫ E · dA)''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-electromagnetism> ;
