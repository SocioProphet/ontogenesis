<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-nuclear-and-atomic-physics-hyperfine-structure> a kcc:GlossaryTerm ;
  skos:prefLabel '''hyperfine structure''' ;
  skos:definition '''Very small splitting of atomic levels due to the interaction between the nuclear magnetic moment and the electronic magnetic field at the nucleus; source of the 21 cm hydrogen line.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-nuclear-and-atomic-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-nuclear-and-atomic-physics-radioactive-decay-law> a kcc:Formula ;
  rdfs:label '''radioactive decay law''' ;
  math:hasStatement '''N(t) = N_0 * exp(-lambda*t);  t_{1/2} = ln(2)/lambda''' ;
  kcc:canonType '''equation''' ;
