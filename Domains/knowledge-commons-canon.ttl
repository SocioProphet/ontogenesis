<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-mathematics-precalculus-and-functions-injective-one-to-one> a kcc:GlossaryTerm ;
  skos:prefLabel '''injective (one-to-one)''' ;
  skos:definition '''A function f is injective if f(a) = f(b) implies a = b; distinct inputs map to distinct outputs.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
