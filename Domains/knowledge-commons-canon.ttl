  skos:prefLabel '''enantiotopic / diastereotopic''' ;
  skos:definition '''Groups that are related by symmetry operations: enantiotopic replacements give enantiomers; diastereotopic replacements give diastereomers.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-organic-reactions-and-mechanisms> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
