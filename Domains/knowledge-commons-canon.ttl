<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-general-relativity-christoffel-symbol> a kcc:GlossaryTerm ;
  skos:prefLabel '''Christoffel symbol''' ;
  skos:definition '''Gamma^lambda_{mu nu} = (1/2)*g^{lambda sigma}*(∂_mu g_{nu sigma} + ∂_nu g_{mu sigma} - ∂_sigma g_{mu nu})''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-general-relativity> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
