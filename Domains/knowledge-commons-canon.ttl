  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> skos:scopeNote '''Bacterial cell structure; Bacterial growth and reproduction; Bacterial metabolism and respiration; Viral structure and replication cycles; Bacteriophage biology; Microbial genetics: transformation, transduction, conjugation; Antimicrobial agents and resistance; Pathogenesis and virulence''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-prokaryote> a kcc:GlossaryTerm ;
  skos:prefLabel '''prokaryote''' ;
  skos:definition '''Single-celled organism lacking a membrane-bound nucleus and organelles; bacteria and archaea; smaller and simpler than eukaryotes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-peptidoglycan> a kcc:GlossaryTerm ;
  skos:prefLabel '''peptidoglycan''' ;
  skos:definition '''The structural polymer of bacterial cell walls forming a mesh-like layer; thicker in gram-positive, thin outer layer in gram-negative bacteria.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-gram-stain> a kcc:GlossaryTerm ;
  skos:prefLabel '''gram stain''' ;
  skos:definition '''Differential staining technique: gram-positive bacteria (thick peptidoglycan) retain crystal violet (purple); gram-negative (thin PG + outer membrane) stain pink with safranin.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-binary-fission> a kcc:GlossaryTerm ;
  skos:prefLabel '''binary fission''' ;
  skos:definition '''Asexual reproduction of bacteria in which the cell replicates its chromosome, elongates, and divides into two identical daughter cells.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-generation-time> a kcc:GlossaryTerm ;
  skos:prefLabel '''generation time''' ;
  skos:definition '''The time required for a bacterial population to double; varies from ~20 minutes (E. coli) to hours or days for slow-growing species.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-lytic-cycle> a kcc:GlossaryTerm ;
  skos:prefLabel '''lytic cycle''' ;
  skos:definition '''Viral replication pathway in which the virus hijacks host machinery, replicates, and lyses the host cell to release progeny virions.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-lysogenic-cycle> a kcc:GlossaryTerm ;
  skos:prefLabel '''lysogenic cycle''' ;
  skos:definition '''Replication pathway in which the viral genome (prophage) integrates into the host chromosome and replicates passively with the host until induced.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-plasmid> a kcc:GlossaryTerm ;
  skos:prefLabel '''plasmid''' ;
  skos:definition '''Small, circular, extrachromosomal DNA element in bacteria that can replicate autonomously and often carries antibiotic resistance genes.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-conjugation> a kcc:GlossaryTerm ;
  skos:prefLabel '''conjugation''' ;
  skos:definition '''Direct transfer of DNA (often a plasmid) between two bacteria via a pilus (sex pilus) and cytoplasmic bridge; requires an F-factor.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-antibiotic-resistance-mechanisms> a kcc:GlossaryTerm ;
  skos:prefLabel '''antibiotic resistance mechanisms''' ;
  skos:definition '''Bacteria resist antibiotics via: enzymatic inactivation (beta-lactamases), target modification, efflux pumps, or reduced permeability.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-endospore> a kcc:GlossaryTerm ;
  skos:prefLabel '''endospore''' ;
  skos:definition '''Highly resistant, metabolically dormant structure formed by some gram-positive bacteria (Bacillus, Clostridium) to survive extreme conditions.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-microbiology-capsid> a kcc:GlossaryTerm ;
  skos:prefLabel '''capsid''' ;
  skos:definition '''The protein shell surrounding a viral genome; composed of protomeric subunits (capsomers); icosahedral or helical symmetry.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-microbiology-bacterial-growth-curve> a kcc:GlossaryTerm ;
  skos:prefLabel '''Bacterial growth curve''' ;
  skos:definition '''Lag phase (metabolic adjustment) → Exponential phase (rapid log growth) → Stationary phase (growth = death, nutrient limitation) → Death phase (exponential die-off).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-microbiology-viral-replication-cycle> a kcc:GlossaryTerm ;
  skos:prefLabel '''Viral replication cycle''' ;
  skos:definition '''Attachment (adsorption) → Penetration (injection/endocytosis) → Uncoating → Biosynthesis (genome replication + protein synthesis) → Assembly → Release (budding or lysis).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-microbiology-horizontal-gene-transfer-in-bacteria> a kcc:GlossaryTerm ;
  skos:prefLabel '''Horizontal gene transfer in bacteria''' ;
  skos:definition '''Three mechanisms: Transformation (uptake of naked DNA), Transduction (bacteriophage-mediated transfer), Conjugation (plasmid transfer via pilus).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-microbiology-antibiotic-targets> a kcc:GlossaryTerm ;
  skos:prefLabel '''Antibiotic targets''' ;
  skos:definition '''Cell wall synthesis (beta-lactams, vancomycin) → lysis; Protein synthesis 30S (aminoglycosides, tetracyclines) or 50S (macrolides, chloramphenicol); DNA gyrase (fluoroquinolones); RNA polymerase (rifampin).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-microbiology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> a kcc:Topic ;
  skos:prefLabel '''Immunology''' ;
  kcc:level '''undergrad''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#domain-biology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> skos:scopeNote '''Innate immunity; Adaptive immunity overview; Antigen presentation and MHC; B cells and antibody production; T cell biology; Immune memory and vaccination; Hypersensitivity reactions; Immunodeficiency and autoimmunity''' .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-antigen> a kcc:GlossaryTerm ;
  skos:prefLabel '''antigen''' ;
  skos:definition '''Any molecule (typically foreign protein) that is recognized by the immune system and can elicit an adaptive immune response.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-antibody-immunoglobulin> a kcc:GlossaryTerm ;
  skos:prefLabel '''antibody (immunoglobulin)''' ;
  skos:definition '''Y-shaped glycoprotein produced by plasma cells; binds specific antigens via variable regions (Fab); effector functions via constant region (Fc).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-b-lymphocyte> a kcc:GlossaryTerm ;
  skos:prefLabel '''B lymphocyte''' ;
  skos:definition '''Adaptive immune cell that matures in bone marrow, expresses B-cell receptor (membrane immunoglobulin), and differentiates into antibody-secreting plasma cells or memory B cells.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-t-lymphocyte> a kcc:GlossaryTerm ;
  skos:prefLabel '''T lymphocyte''' ;
  skos:definition '''Adaptive immune cell that matures in the thymus; CD4+ helper T cells coordinate immune responses; CD8+ cytotoxic T cells kill infected cells.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-mhc-major-histocompatibility-complex> a kcc:GlossaryTerm ;
  skos:prefLabel '''MHC (major histocompatibility complex)''' ;
  skos:definition '''Cell-surface proteins that present peptide antigens to T cells; MHC-I (on all nucleated cells, presents to CD8+ T cells) and MHC-II (on APCs, presents to CD4+ T cells).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-clonal-selection> a kcc:GlossaryTerm ;
  skos:prefLabel '''clonal selection''' ;
  skos:definition '''Process by which an antigen selectively activates the specific lymphocytes bearing complementary receptors, causing them to proliferate (clonal expansion).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-innate-immunity> a kcc:GlossaryTerm ;
  skos:prefLabel '''innate immunity''' ;
  skos:definition '''Non-specific, immediate first-line defense that does not require prior exposure; includes physical barriers, phagocytes, complement, and pattern-recognition receptors (TLRs).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-complement-system> a kcc:GlossaryTerm ;
  skos:prefLabel '''complement system''' ;
  skos:definition '''Cascade of plasma proteins that opsonize pathogens, promote inflammation, and lyse cells via the membrane attack complex (MAC).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-inflammation> a kcc:GlossaryTerm ;
  skos:prefLabel '''inflammation''' ;
  skos:definition '''Vascular and cellular response to infection or injury characterized by redness, heat, swelling, and pain; driven by cytokines, histamine, and prostaglandins.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-opsonization> a kcc:GlossaryTerm ;
  skos:prefLabel '''opsonization''' ;
  skos:definition '''Coating of a pathogen with antibodies or complement (C3b) to enhance recognition and phagocytosis by macrophages and neutrophils.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-cytokine> a kcc:GlossaryTerm ;
  skos:prefLabel '''cytokine''' ;
  skos:definition '''Small signaling protein secreted by immune cells that regulates immune responses (e.g., interleukins, interferons, TNF-α).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-biology-immunology-vaccination> a kcc:GlossaryTerm ;
  skos:prefLabel '''vaccination''' ;
  skos:definition '''Deliberate exposure to an antigen (attenuated pathogen, subunit, mRNA-encoded protein) to prime immunological memory without causing disease.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-immunology-clonal-selection-and-expansion> a kcc:GlossaryTerm ;
  skos:prefLabel '''Clonal selection and expansion''' ;
  skos:definition '''Antigen binds cognate receptor on naive B or T cell → activation (requires costimulation for T cells) → rapid proliferation → effector cells + memory cells.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:canonType '''process''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-immunology-antibody-structure> a kcc:GlossaryTerm ;
  skos:prefLabel '''Antibody structure''' ;
  skos:definition '''Two heavy and two light chains connected by disulfide bonds; Fab regions (variable domains VH + VL) determine antigen specificity; Fc region determines isotype function (IgG, IgM, IgA, IgE, IgD).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-immunology-mhc-i-vs-mhc-ii-presentation> a kcc:GlossaryTerm ;
  skos:prefLabel '''MHC-I vs MHC-II presentation''' ;
  skos:definition '''MHC-I: endogenous (cytoplasmic) peptides loaded in ER → present to CD8+ T cells → cytotoxic response (kills infected cells). MHC-II: exogenous (endocytosed) peptides loaded in lysosomes → present to CD4+ T cells → helper response.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-immunology-primary-vs-secondary-immune-response> a kcc:GlossaryTerm ;
  skos:prefLabel '''Primary vs. secondary immune response''' ;
  skos:definition '''Primary: slow (7–10 days), low-titer IgM, then IgG; creates memory. Secondary: faster (2–3 days), higher-titer IgG, greater affinity (class switching + somatic hypermutation).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-biology-immunology-hypersensitivity-types> a kcc:GlossaryTerm ;
  skos:prefLabel '''Hypersensitivity types''' ;
  skos:definition '''Type I: IgE-mediated immediate (allergy, anaphylaxis). Type II: IgG/IgM against cell-surface antigens. Type III: immune complex deposition. Type IV: delayed-type (T cell-mediated, e.g., contact dermatitis, TB skin test).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-immunology> ;
  kcc:canonType '''definition''' ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-biology-developmental-biology> a kcc:Topic ;
  skos:prefLabel '''Developmental Biology''' ;
  kcc:level '''undergrad''' ;
