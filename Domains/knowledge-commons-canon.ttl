  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-mathematics-precalculus-and-functions-composition-of-inverses> a kcc:GlossaryTerm ;
  skos:prefLabel '''Composition of inverses''' ;
  skos:definition '''(f ∘ f⁻¹)(x) = x = (f⁻¹ ∘ f)(x) whenever defined''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-mathematics-precalculus-and-functions> ;
  kcc:canonType '''definition''' ;
