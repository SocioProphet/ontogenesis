<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-law-of-mass-action-generic> a kcc:Formula ;
  rdfs:label '''Law of mass action (generic)''' ;
  math:hasStatement '''K_c = [C]^c [D]^d / ([A]^a [B]^b)  for aA + bB <=> cC + dD''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-k-p-from-k-c> a kcc:Formula ;
  rdfs:label '''K_p from K_c''' ;
  math:hasStatement '''K_p = K_c * (RT)^(delta_n_gas)  where delta_n_gas = moles gaseous products - moles gaseous reactants''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-reaction-quotient-criterion> a kcc:Formula ;
  rdfs:label '''Reaction quotient criterion''' ;
  math:hasStatement '''Q < K: forward; Q = K: equilibrium; Q > K: reverse''' ;
  kcc:canonType '''law''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-k-for-reverse-reaction> a kcc:Formula ;
  rdfs:label '''K for reverse reaction''' ;
  math:hasStatement '''K_reverse = 1 / K_forward''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-k-for-sum-of-reactions> a kcc:Formula ;
  rdfs:label '''K for sum of reactions''' ;
  math:hasStatement '''K_net = K_1 * K_2 * ...''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-chemical-equilibrium-van-t-hoff-equation-k-vs-t> a kcc:Formula ;
  rdfs:label '''van't Hoff equation (K vs T)''' ;
  math:hasStatement '''ln(K2/K1) = -(delta_H^o/R)*(1/T2 - 1/T1)''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-chemical-equilibrium> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
