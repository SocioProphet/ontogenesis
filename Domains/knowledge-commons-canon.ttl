  skos:prefLabel '''Zaitsev's rule''' ;
  skos:definition '''Elimination reactions preferentially give the more substituted (more stable) alkene product.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-organic-reactions-and-mechanisms> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
