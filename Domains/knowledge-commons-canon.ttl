<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-thermodynamics-classical-carnot-efficiency> a kcc:Formula ;
  rdfs:label '''Carnot efficiency''' ;
  math:hasStatement '''eta = 1 - T_C/T_H''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-thermodynamics-classical> ;
