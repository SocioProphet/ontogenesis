<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-statistical-thermodynamics-and-partition-functions-internal-energy-from-partition-function> a kcc:Formula ;
  rdfs:label '''Internal energy from partition function''' ;
  math:hasStatement '''U = k_B * T^2 * (d ln Q / dT)_V''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-statistical-thermodynamics-and-partition-functions> ;
