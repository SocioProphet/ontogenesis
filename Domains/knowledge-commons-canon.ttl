<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-mathematical-methods-in-physics-divergence> a kcc:GlossaryTerm ;
  skos:prefLabel '''divergence''' ;
  skos:definition '''∇·F = ∂F_x/∂x + ∂F_y/∂y + ∂F_z/∂z; measures the outward flux per unit volume of a vector field; appears in Gauss's law.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-mathematical-methods-in-physics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
