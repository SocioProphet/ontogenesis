<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-partial-pressure> a kcc:GlossaryTerm ;
  skos:prefLabel '''partial pressure''' ;
  skos:definition '''The pressure a gas would exert if it alone occupied the total volume at the same temperature.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-mole-fraction> a kcc:GlossaryTerm ;
  skos:prefLabel '''mole fraction''' ;
  skos:definition '''The ratio of moles of one component to total moles in a mixture; chi_i = n_i / n_total.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-root-mean-square-speed> a kcc:GlossaryTerm ;
  skos:prefLabel '''root-mean-square speed''' ;
  skos:definition '''The square root of the mean of the squared molecular speeds, equal to sqrt(3RT/M).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-effusion> a kcc:GlossaryTerm ;
  skos:prefLabel '''effusion''' ;
  skos:definition '''The passage of a gas through a tiny orifice into a vacuum; rate inversely proportional to sqrt(molar mass).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-van-der-waals-constants> a kcc:GlossaryTerm ;
  skos:prefLabel '''van der Waals constants''' ;
  skos:definition '''Empirical parameters a (accounts for intermolecular attractions) and b (accounts for molecular volume) in the van der Waals real-gas equation.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-compressibility-factor-z> a kcc:GlossaryTerm ;
  skos:prefLabel '''compressibility factor Z''' ;
  skos:definition '''The ratio PV/(nRT); equals 1 for an ideal gas and deviates from 1 for real gases.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-chemistry-gases-and-kinetic-molecular-theory-standard-temperature-and-pressure-stp> a kcc:GlossaryTerm ;
  skos:prefLabel '''standard temperature and pressure (STP)''' ;
  skos:definition '''Defined by IUPAC as 0 degrees C (273.15 K) and 100 kPa; molar volume of ideal gas = 22.711 L/mol.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-gases-and-kinetic-molecular-theory> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
  skos:inScheme kcc:CanonScheme .
