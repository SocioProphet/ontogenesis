  skos:prefLabel '''trans effect''' ;
  skos:definition '''The ability of a ligand to labilize (facilitate substitution of) the ligand trans to it; strongest for high-field ligands (CO, CN-, H-).''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-coordination-chemistry-and-inorganic-chemistry> ;
