<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-quantum-mechanics-first-order-energy-correction-perturbation-theory> a kcc:Formula ;
  rdfs:label '''first-order energy correction (perturbation theory)''' ;
  math:hasStatement '''E_n^(1) = <n^(0)|H'|n^(0)>''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-quantum-mechanics> ;
