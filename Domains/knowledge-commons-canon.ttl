<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#term-physics-plasma-physics-and-fluid-dynamics-debye-length> a kcc:GlossaryTerm ;
  skos:prefLabel '''Debye length''' ;
  skos:definition '''λ_D = sqrt(ε_0 k_B T_e / (n_e e^2)); the characteristic length over which charge imbalances are screened by rearrangement of free charges in a plasma.''' ;
  skos:broader <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-plasma-physics-and-fluid-dynamics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext ;
