<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-thermodynamic-relations-from-f> a kcc:Formula ;
  rdfs:label '''thermodynamic relations from F''' ;
  math:hasStatement '''S = -(∂F/∂T)_V;  P = -(∂F/∂V)_T;  U = F + T*S''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-physics-statistical-mechanics-and-thermodynamics-gibbs-free-energy> a kcc:Formula ;
  rdfs:label '''Gibbs free energy''' ;
  math:hasStatement '''G = U + P*V - T*S = F + P*V''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-physics-statistical-mechanics-and-thermodynamics> ;
