<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-electrochemistry-nernst-equation> a kcc:Formula ;
  rdfs:label '''Nernst equation''' ;
  math:hasStatement '''E = E^o - (R*T)/(n*F) * ln(Q)  =>  E = E^o - (0.05916/n) * log(Q) at 298 K''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-electrochemistry> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-electrochemistry-equilibrium-from-e-o> a kcc:Formula ;
  rdfs:label '''Equilibrium from E^o''' ;
  math:hasStatement '''ln(K) = n*F*E^o / (R*T)  =>  log(K) = n*E^o / 0.05916 at 298 K''' ;
  kcc:canonType '''equation''' ;
  dct:subject <https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#topic-chemistry-electrochemistry> ;
  kcc:inKnowledgeContext kcc:CanonKnowledgeContext .
<https://socioprophet.github.io/ontogenesis/domains/knowledge-commons-canon#formula-chemistry-electrochemistry-faraday-s-first-law> a kcc:Formula ;
  rdfs:label '''Faraday's first law''' ;
  math:hasStatement '''m = (M * I * t) / (n * F)  where m=mass deposited, M=molar mass, I=current, t=time''' ;
  kcc:canonType '''law''' ;
