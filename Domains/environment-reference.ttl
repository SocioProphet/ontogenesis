@base <https://socioprophet.github.io/ontogenesis/> .
@prefix enrm:  <https://socioprophet.github.io/ontogenesis/domains/environment-reference#> .
@prefix cstack:<https://socioprophet.github.io/ontogenesis/civic-stack#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix org:   <http://www.w3.org/ns/org#> .
@prefix geo:   <http://www.opengis.net/ont/geosparql#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Domains/environment-reference.ttl> a owl:Ontology ;
  dct:title "Domain — Environment Reference Model" ;
  dct:description "EnRM primitives for environmental factors, resource stocks, carrying capacities, externalities, exposures, hazards, vulnerabilities, critical infrastructure, and environmental evidence in the Seven-Model Civic Operating Architecture." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Alignments/w3c-org.ttl> .

enrm:EnvironmentFactor a owl:Class ;
  rdfs:subClassOf cstack:CivicStackObject ;
  rdfs:label "Environment factor" .

enrm:ResourceStock a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Resource stock" .

enrm:CarryingCapacity a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Carrying capacity" .

enrm:Externality a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Externality" .

enrm:Exposure a owl:Class ;
  rdfs:subClassOf cstack:EnvironmentalExposure ;
  rdfs:label "Exposure" .

enrm:Hazard a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Hazard" .

enrm:Vulnerability a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Vulnerability" .

enrm:CriticalInfrastructure a owl:Class ;
  rdfs:subClassOf upper:System ;
  rdfs:label "Critical infrastructure" .

enrm:GridCarbonIntensity a owl:Class ;
  rdfs:subClassOf enrm:Exposure ;
  rdfs:label "Grid carbon intensity" .

enrm:EnergyUse a owl:Class ;
  rdfs:subClassOf enrm:Externality ;
  rdfs:label "Energy use" .

enrm:EmissionsEstimate a owl:Class ;
  rdfs:subClassOf enrm:Externality ;
  rdfs:label "Emissions estimate" .

enrm:PlaceConstraint a owl:Class ;
  rdfs:subClassOf enrm:EnvironmentFactor ;
  rdfs:label "Place constraint" .

enrm:EnvironmentalEvidence a owl:Class ;
  rdfs:subClassOf upper:Evidence ;
  rdfs:label "Environmental evidence" .

enrm:hasEnvironmentFactor a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range enrm:EnvironmentFactor ;
  rdfs:label "has environment factor" .

enrm:hasExposure a owl:ObjectProperty ;
  rdfs:subPropertyOf cstack:hasExposure ;
  rdfs:domain org:Site ;
  rdfs:range enrm:Exposure ;
  rdfs:label "has exposure" .

enrm:hasHazard a owl:ObjectProperty ;
  rdfs:domain org:Site ;
  rdfs:range enrm:Hazard ;
  rdfs:label "has hazard" .

enrm:hasVulnerability a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range enrm:Vulnerability ;
  rdfs:label "has vulnerability" .

enrm:consumesResource a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range enrm:ResourceStock ;
  rdfs:label "consumes resource" .

enrm:producesExternality a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range enrm:Externality ;
  rdfs:label "produces externality" .

enrm:constrainedByCapacity a owl:ObjectProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range enrm:CarryingCapacity ;
  rdfs:label "constrained by capacity" .

enrm:protectsInfrastructure a owl:ObjectProperty ;
  rdfs:domain enrm:Hazard ;
  rdfs:range enrm:CriticalInfrastructure ;
  rdfs:label "protects infrastructure" .

enrm:hasGeometry a owl:ObjectProperty ;
  rdfs:domain enrm:PlaceConstraint ;
  rdfs:range geo:Geometry ;
  rdfs:label "has geometry" .

enrm:hasEvidence a owl:ObjectProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range enrm:EnvironmentalEvidence ;
  rdfs:label "has environmental evidence" .

enrm:evidenceGeneratedBy a owl:ObjectProperty ;
  rdfs:domain enrm:EnvironmentalEvidence ;
  rdfs:range prov:Activity ;
  rdfs:label "evidence generated by" .

enrm:emissionsKgCO2e a owl:DatatypeProperty ;
  rdfs:subPropertyOf cstack:emissionsKgCO2e ;
  rdfs:domain upper:Entity ;
  rdfs:range xsd:decimal ;
  rdfs:label "emissions kg CO2e" .

enrm:energyKWh a owl:DatatypeProperty ;
  rdfs:domain upper:Entity ;
  rdfs:range xsd:decimal ;
  rdfs:label "energy kWh" .

enrm:measurementValue a owl:DatatypeProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range xsd:decimal ;
  rdfs:label "measurement value" .

enrm:measurementUnit a owl:DatatypeProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range xsd:string ;
  rdfs:label "measurement unit" .

enrm:validFrom a owl:DatatypeProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range xsd:dateTime ;
  rdfs:label "valid from" .

enrm:validUntil a owl:DatatypeProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range xsd:dateTime ;
  rdfs:label "valid until" .

enrm:confidence a owl:DatatypeProperty ;
  rdfs:domain enrm:EnvironmentFactor ;
  rdfs:range xsd:decimal ;
  rdfs:label "confidence" .
