@base <https://socioprophet.github.io/ontogenesis/> .
@prefix fin:   <https://socioprophet.github.io/ontogenesis/domains/finance#> .
@prefix biz:   <https://socioprophet.github.io/ontogenesis/domains/business#> .
@prefix legal: <https://socioprophet.github.io/ontogenesis/domains/legal#> .
@prefix party: <https://socioprophet.github.io/ontogenesis/domains/party#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Domains/finance.ttl> a owl:Ontology ;
  dct:title "Domain — Finance" ;
  dct:description "Finance-sector semantics for accounts, transactions, counterparties, instruments, beneficial ownership, KYC/AML evidence, sanctions screening, and risk scoring." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl>, <Domains/business_core.ttl>, <Domains/org-legal.ttl>, <Domains/party-identity.ttl> .

fin:FinancialAccount a owl:Class ; rdfs:subClassOf party:Account ; rdfs:label "Financial account" .
fin:FinancialTransaction a owl:Class ; rdfs:subClassOf upper:Process ; rdfs:label "Financial transaction" .
fin:Counterparty a owl:Class ; rdfs:subClassOf party:Party ; rdfs:label "Counterparty" .
fin:FinancialInstrument a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Financial instrument" .
fin:BeneficialOwnershipRelation a owl:Class ; rdfs:subClassOf legal:OwnershipRelation ; rdfs:label "Beneficial ownership relation" .
fin:KYCProfile a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "KYC profile" .
fin:AMLAlert a owl:Class ; rdfs:subClassOf upper:Evidence ; rdfs:label "AML alert" .
fin:SanctionsScreeningResult a owl:Class ; rdfs:subClassOf upper:Evidence ; rdfs:label "Sanctions screening result" .
fin:RiskScore a owl:Class ; rdfs:subClassOf upper:InformationArtifact ; rdfs:label "Risk score" .
fin:TransactionNetworkPattern a owl:Class ; rdfs:subClassOf upper:Evidence ; rdfs:label "Transaction network pattern" .

fin:hasSender a owl:ObjectProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range party:Party ; rdfs:label "has sender" .
fin:hasRecipient a owl:ObjectProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range party:Party ; rdfs:label "has recipient" .
fin:usesAccount a owl:ObjectProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range fin:FinancialAccount ; rdfs:label "uses account" .
fin:hasCounterparty a owl:ObjectProperty ; rdfs:domain upper:Entity ; rdfs:range fin:Counterparty ; rdfs:label "has counterparty" .
fin:hasInstrument a owl:ObjectProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range fin:FinancialInstrument ; rdfs:label "has instrument" .
fin:hasKYCProfile a owl:ObjectProperty ; rdfs:domain party:Party ; rdfs:range fin:KYCProfile ; rdfs:label "has KYC profile" .
fin:hasSanctionsScreeningResult a owl:ObjectProperty ; rdfs:domain party:Party ; rdfs:range fin:SanctionsScreeningResult ; rdfs:label "has sanctions screening result" .
fin:hasRiskScore a owl:ObjectProperty ; rdfs:domain upper:Entity ; rdfs:range fin:RiskScore ; rdfs:label "has risk score" .
fin:beneficialOwner a owl:ObjectProperty ; rdfs:domain fin:BeneficialOwnershipRelation ; rdfs:range party:Party ; rdfs:label "beneficial owner" .
fin:ownedLegalEntity a owl:ObjectProperty ; rdfs:domain fin:BeneficialOwnershipRelation ; rdfs:range legal:LegalEntity ; rdfs:label "owned legal entity" .
fin:alertSubject a owl:ObjectProperty ; rdfs:domain fin:AMLAlert ; rdfs:range upper:Entity ; rdfs:label "alert subject" .
fin:patternInvolvesTransaction a owl:ObjectProperty ; rdfs:domain fin:TransactionNetworkPattern ; rdfs:range fin:FinancialTransaction ; rdfs:label "pattern involves transaction" .

fin:amount a owl:DatatypeProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range xsd:decimal ; rdfs:label "amount" .
fin:currency a owl:DatatypeProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range xsd:string ; rdfs:label "currency" .
fin:transactedAt a owl:DatatypeProperty ; rdfs:domain fin:FinancialTransaction ; rdfs:range xsd:dateTime ; rdfs:label "transacted at" .
fin:riskValue a owl:DatatypeProperty ; rdfs:domain fin:RiskScore ; rdfs:range xsd:decimal ; rdfs:label "risk value" .
fin:riskModel a owl:DatatypeProperty ; rdfs:domain fin:RiskScore ; rdfs:range xsd:string ; rdfs:label "risk model" .
fin:alertStatus a owl:DatatypeProperty ; rdfs:domain fin:AMLAlert ; rdfs:range xsd:string ; rdfs:label "alert status" .
fin:screeningStatus a owl:DatatypeProperty ; rdfs:domain fin:SanctionsScreeningResult ; rdfs:range xsd:string ; rdfs:label "screening status" .
fin:instrumentType a owl:DatatypeProperty ; rdfs:domain fin:FinancialInstrument ; rdfs:range xsd:string ; rdfs:label "instrument type" .
