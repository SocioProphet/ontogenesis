@base <https://socioprophet.github.io/ontogenesis/> .
@prefix kc:    <https://socioprophet.github.io/ontogenesis/platform/knowledge-context#> .
@prefix plat:  <https://socioprophet.github.io/ontogenesis/platform#> .
@prefix upper: <https://socioprophet.github.io/ontogenesis/upper#> .
@prefix middle:<https://socioprophet.github.io/ontogenesis/middle#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix schema:<https://schema.org/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<Platform/knowledge-context.ttl> a owl:Ontology ;
  dct:title "SocioProphet Knowledge Context Ontology" ;
  dct:description "Semantic governance module for Knowledge Context v1 contracts: passages, mentions, entities, claims, provenance, embeddings, vector index references, and entity resolution records." ;
  owl:versionInfo "0.1.0" ;
  owl:imports <Upper/upper-core.ttl> ;
  owl:imports <Middle/system-architecture.ttl> ;
  owl:imports <Platform/platform.ttl> .

kc:KnowledgeContext a owl:Class ;
  rdfs:subClassOf plat:Component ;
  rdfs:label "Knowledge Context" ;
  rdfs:comment "A governed semantic context for canonical knowledge artifacts and graph/vector retrieval surfaces." .

kc:KnowledgeArtifact a owl:Class ;
  rdfs:subClassOf upper:InformationArtifact ;
  rdfs:label "Knowledge artifact" .

kc:Note a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact, schema:CreativeWork ; rdfs:label "Note" .
kc:Claim a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Claim" .
kc:Annotation a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Annotation" .
kc:Passage a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact, schema:CreativeWork ; rdfs:label "Passage" .
kc:Entity a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact, schema:Thing ; rdfs:label "Entity" .
kc:Mention a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Mention" .
kc:MeriotopographicEdge a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Meriotopographic edge" .
kc:ProvenanceRecord a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact, prov:Activity ; rdfs:label "Provenance record" .
kc:EmbeddingRef a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Embedding reference" .
kc:VectorIndexRef a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Vector index reference" .
kc:EntityResolutionRecord a owl:Class ; rdfs:subClassOf kc:KnowledgeArtifact ; rdfs:label "Entity resolution record" .

kc:hasArtifact a owl:ObjectProperty ; rdfs:domain kc:KnowledgeContext ; rdfs:range kc:KnowledgeArtifact ; rdfs:label "has artifact" .
kc:hasPassage a owl:ObjectProperty ; rdfs:domain kc:KnowledgeContext ; rdfs:range kc:Passage ; rdfs:label "has passage" .
kc:mentionsEntity a owl:ObjectProperty ; rdfs:domain kc:Mention ; rdfs:range kc:Entity ; rdfs:label "mentions entity" .
kc:inPassage a owl:ObjectProperty ; rdfs:domain kc:Mention ; rdfs:range kc:Passage ; rdfs:label "in passage" .
kc:hasEvidence a owl:ObjectProperty ; rdfs:domain kc:Claim ; rdfs:range kc:KnowledgeArtifact ; rdfs:label "has evidence" .
kc:generatedBy a owl:ObjectProperty ; rdfs:domain kc:KnowledgeArtifact ; rdfs:range kc:ProvenanceRecord ; rdfs:subPropertyOf prov:wasGeneratedBy ; rdfs:label "generated by" .
kc:targetsNode a owl:ObjectProperty ; rdfs:domain kc:EmbeddingRef ; rdfs:range kc:KnowledgeArtifact ; rdfs:label "targets node" .
kc:usesVectorIndex a owl:ObjectProperty ; rdfs:domain kc:EmbeddingRef ; rdfs:range kc:VectorIndexRef ; rdfs:label "uses vector index" .
kc:resolvedEntity a owl:ObjectProperty ; rdfs:domain kc:EntityResolutionRecord ; rdfs:range kc:Entity ; rdfs:label "resolved entity" .
kc:candidateEntity a owl:ObjectProperty ; rdfs:domain kc:EntityResolutionRecord ; rdfs:range kc:Entity ; rdfs:label "candidate entity" .

kc:artifactId a owl:DatatypeProperty ; rdfs:domain kc:KnowledgeArtifact ; rdfs:range xsd:string ; rdfs:label "artifact id" .
kc:confidence a owl:DatatypeProperty ; rdfs:domain kc:KnowledgeArtifact ; rdfs:range xsd:decimal ; rdfs:label "confidence" .
kc:text a owl:DatatypeProperty ; rdfs:domain kc:Passage ; rdfs:range xsd:string ; rdfs:label "text" .
kc:surfaceForm a owl:DatatypeProperty ; rdfs:domain kc:Mention ; rdfs:range xsd:string ; rdfs:label "surface form" .
kc:embeddingModel a owl:DatatypeProperty ; rdfs:domain kc:EmbeddingRef ; rdfs:range xsd:string ; rdfs:label "embedding model" .
kc:vectorBackend a owl:DatatypeProperty ; rdfs:domain kc:VectorIndexRef ; rdfs:range xsd:string ; rdfs:label "vector backend" .
kc:metric a owl:DatatypeProperty ; rdfs:domain kc:VectorIndexRef ; rdfs:range xsd:string ; rdfs:label "metric" .
kc:schemaLabel a owl:DatatypeProperty ; rdfs:domain kc:KnowledgeContext ; rdfs:range xsd:string ; rdfs:label "schema label" .
kc:contextLabel a owl:DatatypeProperty ; rdfs:domain kc:KnowledgeContext ; rdfs:range xsd:string ; rdfs:label "context label" .

kc:KnowledgeContextV1 a kc:KnowledgeContext ;
  rdfs:label "Knowledge Context v1" ;
  kc:schemaLabel "KNOWLEDGE_AVRO_v1" ;
  kc:contextLabel "KNOWLEDGE_JSONLD_v1" ;
  plat:runsInSpace middle:INCEPTION .
