@prefix : <https://socioprophet.github.io/ontogenesis/Platform/Parsing/link-grammar#> .
@prefix core: <https://socioprophet.github.io/ontogenesis/Platform/Parsing/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://socioprophet.github.io/ontogenesis/Platform/Parsing/link-grammar>
  a owl:Ontology ;
  owl:imports <https://socioprophet.github.io/ontogenesis/Platform/Parsing/core> ;
  rdfs:label "SocioProphet Link Grammar Ontology" ;
  rdfs:comment "Link Grammar-specific vocabulary layered over the parsing core ontology." .

:LinkGrammarConnector a owl:Class ;
  rdfs:subClassOf core:Connector ;
  rdfs:label "Link Grammar Connector" .

:Disjunct a owl:Class ;
  rdfs:label "Disjunct" ;
  rdfs:comment "Lexical connector bundle emitted by a Link Grammar lexicon entry." .

:LinkGrammarLinkage a owl:Class ;
  rdfs:subClassOf core:Linkage ;
  rdfs:label "Link Grammar Linkage" .

:ParseFailure a owl:Class ;
  rdfs:label "Parse Failure" ;
  rdfs:comment "Parser failure or degraded parse-state emitted when no admissible linkage is available." .

:LexiconEntry a owl:Class ;
  rdfs:label "Lexicon Entry" .

:usesDisjunct a owl:ObjectProperty ;
  rdfs:domain :LexiconEntry ;
  rdfs:range :Disjunct ;
  rdfs:label "uses disjunct" .

:emitsConnector a owl:ObjectProperty ;
  rdfs:domain :Disjunct ;
  rdfs:range :LinkGrammarConnector ;
  rdfs:label "emits connector" .

:licensedByLexiconEntry a owl:ObjectProperty ;
  rdfs:domain core:Token ;
  rdfs:range :LexiconEntry ;
  rdfs:label "licensed by lexicon entry" .

:connectorLabel a owl:DatatypeProperty ;
  rdfs:domain :LinkGrammarConnector ;
  rdfs:range xsd:string ;
  rdfs:label "connector label" .

:connectorDirection a owl:DatatypeProperty ;
  rdfs:domain :LinkGrammarConnector ;
  rdfs:range xsd:string ;
  rdfs:label "connector direction" .

:disjunctCost a owl:DatatypeProperty ;
  rdfs:domain :Disjunct ;
  rdfs:range xsd:decimal ;
  rdfs:label "disjunct cost" .

:failureReason a owl:DatatypeProperty ;
  rdfs:domain :ParseFailure ;
  rdfs:range xsd:string ;
  rdfs:label "failure reason" .
